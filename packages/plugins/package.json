{
  "name": "@andresclua/sliderkit-plugins",
  "version": "2.0.0",
  "description": "SliderKit plugins — arrows, pagination, autoplay, thumbs, progress, mouseWheel, keyboard, a11y, hooks",
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./css/*": "./dist/css/*",
    "./scss/*": "./src/scss/*"
  },
  "files": [
    "dist",
    "src/scss",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "homepage": "https://sliderkit.andresclua.com/docs/plugins",
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@andresclua/sliderkit": "^2.0.0"
  },
  "devDependencies": {
    "vite": "^5.2.12",
    "vite-plugin-dts": "^3.9.1",
    "typescript": "^5.4.5",
    "@andresclua/sliderkit": "workspace:*"
  },
  "keywords": ["slider", "carousel", "sliderkit", "plugins", "pagination", "autoplay"],
  "author": "Andres Clua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andresclua/sliderkit",
    "directory": "packages/plugins"
  }
}
