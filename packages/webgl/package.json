{
  "name": "@andresclua/sliderkit-webgl",
  "version": "2.0.0",
  "description": "SliderKit WebGL plugin — GPU-powered transitions (displacement, rgb-shift, radial, custom GLSL)",
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./css/*": "./dist/css/*",
    "./scss/*": "./src/scss/*",
    "./textures/*": "./textures/*"
  },
  "files": ["dist", "src/scss", "textures", "README.md"],
  "sideEffects": ["**/*.css", "**/*.scss"],
  "homepage": "https://sliderkit.andresclua.com/docs/plugins/webgl",
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@andresclua/sliderkit": "^2.0.0",
    "gsap": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "gsap": { "optional": true }
  },
  "devDependencies": {
    "vite": "^5.2.12",
    "vite-plugin-dts": "^3.9.1",
    "typescript": "^5.4.5",
    "@andresclua/sliderkit": "workspace:*"
  },
  "keywords": ["slider", "carousel", "sliderkit", "webgl", "displacement", "shader", "glsl"],
  "author": "Andres Clua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andresclua/sliderkit",
    "directory": "packages/webgl"
  }
}
