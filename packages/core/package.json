{
  "name": "@andresclua/sliderkit",
  "version": "2.0.0",
  "description": "SliderKit core engine — accessible, TypeScript-first slider",
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./css/*": "./dist/css/*",
    "./scss/*": "./src/scss/*"
  },
  "files": [
    "dist",
    "src/scss",
    "README.md"
  ],
  "homepage": "https://sliderkit.andresclua.com",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "size-check": "node -e \"const fs=require('fs');const s=fs.statSync('dist/index.mjs').size;if(s>8192*4){process.exit(1)}\""
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vite-plugin-dts": "^3.9.1"
  },
  "keywords": [
    "slider",
    "carousel",
    "sliderkit",
    "typescript",
    "accessible"
  ],
  "author": "Andres Clua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andresclua/sliderkit",
    "directory": "packages/core"
  }
}
