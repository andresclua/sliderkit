---
import BaseLayout from './BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import Sidebar from '../components/Sidebar.astro'
import { docsNav } from '../nav'

interface Props {
  title?: string
  description?: string
}
const { title, description } = Astro.props
const currentPath = Astro.url.pathname
---
<BaseLayout title={title} description={description}>
  <SiteHeader />
  <div class="docs-shell">
    <Sidebar nav={docsNav} currentPath={currentPath} />
    <main class="docs-main">
      <div class="docs-content">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
.docs-shell {
  display: flex;
  min-height: calc(100vh - var(--header-h));
  padding-top: var(--header-h);
}
.docs-main {
  flex: 1;
  min-width: 0;
  padding: 2rem 2.5rem;
}
.docs-content {
  max-width: 780px;
  margin: 0 auto;
}
/* Docs prose */
.docs-content :global(h1) {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  line-height: 1.2;
}
.docs-content :global(h2) {
  font-size: 1.35rem;
  font-weight: 600;
  margin-top: 2.5rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--border);
}
.docs-content :global(h3) {
  font-size: 1.1rem;
  font-weight: 600;
  margin-top: 1.75rem;
  margin-bottom: 0.5rem;
}
.docs-content :global(p) {
  margin-bottom: 1rem;
  color: #374151;
}
.docs-content :global(ul), .docs-content :global(ol) {
  margin: 0 0 1rem 1.5rem;
}
.docs-content :global(li) { margin-bottom: 0.3rem; }
.docs-content :global(pre) { margin: 1.25rem 0; }
.docs-content :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
  margin: 1.25rem 0;
}
.docs-content :global(th) {
  text-align: left;
  padding: 8px 12px;
  background: #f3f4f6;
  border: 1px solid var(--border);
  font-weight: 600;
}
.docs-content :global(td) {
  padding: 8px 12px;
  border: 1px solid var(--border);
  vertical-align: top;
}
.docs-content :global(tr:nth-child(even) td) { background: #fafafa; }
.docs-content :global(.lead) {
  font-size: 1.1rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}
.docs-content :global(.code-label) {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--brand);
  margin: 1.5rem 0 0.25rem;
}
.docs-content :global(.badge) {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 99px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.docs-content :global(.badge-purple) { background: #ede9fe; color: var(--brand); }
.docs-content :global(.badge-green)  { background: #d1fae5; color: #065f46; }
.docs-content :global(.badge-blue)   { background: #dbeafe; color: #1e40af; }

@media (max-width: 768px) {
  .docs-main { padding: 1.25rem 1rem; }
}
</style>
