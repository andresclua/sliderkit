<div class="sponsor-banner">
  <span class="sponsor-heart">♥</span>
  <div>
    <strong>SliderKit is free and open source.</strong>
    If it saves you time, consider sponsoring development.
  </div>
  <a href="https://github.com/sponsors/andresclua" target="_blank" rel="noopener" class="sponsor-btn">
    Sponsor on GitHub
  </a>
</div>

<style>
.sponsor-banner {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: linear-gradient(135deg, #fce7f3, #ede9fe);
  border: 1px solid #e9d5ff;
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  margin: 2rem 0;
  font-size: 0.9rem;
}
.sponsor-heart { font-size: 1.5rem; flex-shrink: 0; }
.sponsor-btn {
  margin-left: auto;
  flex-shrink: 0;
  padding: 8px 16px;
  background: var(--brand);
  color: #fff;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
}
.sponsor-btn:hover { background: var(--brand-dark); text-decoration: none; }
</style>
