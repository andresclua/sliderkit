---
interface Props {
  title: string
  description?: string
  code?: string   // JS (legacy single-block)
  html?: string
  css?: string
  js?: string
}
const { title, description, code, html, css, js } = Astro.props
const jsCode = js ?? code

// ── CSS → SCSS auto-converter ─────────────────────────────────────────────────
function cssToScss(raw: string): string {
  if (!raw?.trim()) return raw ?? ''

  // Strip block comments so they don't contaminate selector strings
  const stripped = raw.replace(/\/\*[\s\S]*?\*\//g, '')

  // Parse all rules: { selector, body }
  const rules: { selector: string; body: string }[] = []
  const re = /([^{}]+)\{([^}]*)\}/g
  let m: RegExpExecArray | null
  while ((m = re.exec(stripped)) !== null) {
    const sel  = m[1].trim()
    const body = m[2]
    if (sel && body.trim()) rules.push({ selector: sel, body })
  }
  if (!rules.length) return raw

  // Find BEM roots: selectors that are "simple" (only letters/numbers/hyphens after the dot)
  // AND have at least one child selector starting with sel + '__'
  const candidateRoots = rules
    .map(r => r.selector)
    .filter(sel => {
      const isSimple = /^\.[a-zA-Z][a-zA-Z0-9-]*$/.test(sel)
      const hasChildren = rules.some(r2 => r2.selector !== sel && r2.selector.startsWith(sel + '__'))
      return isSimple && hasChildren
    })

  if (!candidateRoots.length) return raw

  // Format a declarations block with a given indent
  const formatBody = (body: string, indent: string) =>
    body.split(';')
      .map(p => p.trim())
      .filter(Boolean)
      .map(p => `${indent}${p};`)
      .join('\n')

  // Mark everything that belongs to a BEM root as "accounted for"
  const isBemChild = (sel: string) =>
    candidateRoots.some(
      root => sel !== root && (sel.startsWith(root + '__') || sel.startsWith(root + '--'))
    )

  const processedSelectors = new Set<string>()
  const output: string[] = []

  // ── 1. Standalone rules (not a BEM root and not a BEM child) ────────────────
  rules.forEach(rule => {
    if (candidateRoots.includes(rule.selector)) return
    if (isBemChild(rule.selector)) return

    output.push(`${rule.selector} {`)
    output.push(formatBody(rule.body, '  '))
    output.push('}\n')
    processedSelectors.add(rule.selector)
  })

  // ── 2. BEM roots with nested children ───────────────────────────────────────
  candidateRoots.forEach(root => {
    const rootRule = rules.find(r => r.selector === root)
    const children = rules.filter(
      r => r.selector !== root &&
           (r.selector.startsWith(root + '__') || r.selector.startsWith(root + '--'))
    )

    output.push(`${root} {`)
    if (rootRule) output.push(formatBody(rootRule.body, '  '))

    // Group children by their element segment (the part up to the first --)
    const elementMap = new Map<string, typeof children>()
    const directMods: typeof children = []

    children.forEach(child => {
      const rest = child.selector.slice(root.length) // e.g. "__wrapper", "__arrow--prev"

      if (rest.startsWith('__')) {
        // Element name = everything up to the first standalone '--'
        // "__pagination-bullet--active" → "__pagination-bullet"
        // "__arrow--prev"               → "__arrow"
        const dashIdx = rest.indexOf('--', 2)           // skip the leading "__"
        const elemKey = dashIdx > 0 ? rest.slice(0, dashIdx) : rest
        if (!elementMap.has(elemKey)) elementMap.set(elemKey, [])
        elementMap.get(elemKey)!.push(child)
      } else if (rest.startsWith('--')) {
        directMods.push(child)
      }
    })

    // Output each element group (with modifiers nested inside if present)
    elementMap.forEach((elemChildren, elemSuffix) => {
      const elemSelector = root + elemSuffix
      const elemRule     = elemChildren.find(c => c.selector === elemSelector)
      const elemMods     = elemChildren.filter(c => c.selector !== elemSelector)

      output.push(`\n  &${elemSuffix} {`)
      if (elemRule) output.push(formatBody(elemRule.body, '    '))

      elemMods.forEach(mod => {
        const modSuffix = mod.selector.slice(elemSelector.length) // e.g. "--active"
        output.push(`\n    &${modSuffix} {`)
        output.push(formatBody(mod.body, '      '))
        output.push(`    }`)
      })

      output.push(`  }`)
    })

    // Direct root modifiers (e.g. .sliderkit--disabled)
    directMods.forEach(mod => {
      const modSuffix = mod.selector.slice(root.length)
      output.push(`\n  &${modSuffix} {`)
      output.push(formatBody(mod.body, '    '))
      output.push(`  }`)
    })

    output.push(`}\n`)
  })

  return output.join('\n').replace(/\n{3,}/g, '\n\n').trim()
}

const scss = css ? cssToScss(css) : undefined

const hasTabs = !!(html || css || jsCode)
const tabs = [
  html  ? { id: 'html', label: 'HTML', content: html }    : null,
  css   ? { id: 'css',  label: 'CSS',  content: css }     : null,
  scss  ? { id: 'scss', label: 'SCSS', content: scss }    : null,
  jsCode ? { id: 'js',  label: 'JS',   content: jsCode }  : null,
].filter(Boolean) as { id: string; label: string; content: string }[]
const multiTab = tabs.length > 1
---
<section class="demo-viewer">
  <header class="demo-header">
    <h1 class="demo-title">{title}</h1>
    {description && <p class="demo-description">{description}</p>}
  </header>

  <div class="demo-stage">
    <slot />
  </div>

  {hasTabs && (
    <details class="demo-code" open>
      <summary>View code</summary>
      {multiTab ? (
        <div class="demo-tabs" data-tabs>
          <div class="demo-tab-bar">
            {tabs.map((tab, i) => (
              <button
                class={`demo-tab-btn${i === 0 ? ' is-active' : ''}`}
                data-tab={tab.id}
                type="button"
              >{tab.label}</button>
            ))}
          </div>
          {tabs.map((tab, i) => (
            <div class={`demo-tab-panel${i === 0 ? ' is-active' : ''}`} data-panel={tab.id}>
              <pre><code>{tab.content}</code></pre>
            </div>
          ))}
        </div>
      ) : (
        <pre><code>{tabs[0].content}</code></pre>
      )}
    </details>
  )}
</section>

<style>
.demo-viewer { margin-bottom: 4rem; }
.demo-viewer:last-child { margin-bottom: 0; }

.demo-header { margin-bottom: 1.5rem; }
.demo-title {
  font-size: 1.6rem;
  font-weight: 700;
  margin-bottom: 0.4rem;
  line-height: 1.2;
}
.demo-description { color: var(--text-muted); font-size: 0.95rem; }

.demo-stage {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1rem;
  overflow: hidden;
}

.demo-code {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.demo-code summary {
  padding: 0.6rem 1rem;
  background: #f9fafb;
  cursor: pointer;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-muted);
  user-select: none;
}
.demo-code summary:hover { background: #f3f4f6; }
.demo-code pre { margin: 0; border-radius: 0; }

/* Tabs */
.demo-tab-bar {
  display: flex;
  gap: 0;
  background: #1e1e2e;
  border-bottom: 1px solid #333;
}
.demo-tab-btn {
  padding: 0.5rem 1.1rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: #888;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s;
}
.demo-tab-btn:hover { color: #ccc; }
.demo-tab-btn.is-active { color: #fff; border-bottom-color: var(--brand); }

.demo-tab-panel { display: none; }
.demo-tab-panel.is-active { display: block; }
.demo-tab-panel pre { margin: 0; border-radius: 0; }
</style>

<script>
document.querySelectorAll('[data-tabs]').forEach(tabs => {
  tabs.querySelectorAll('.demo-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-tab')
      tabs.querySelectorAll('.demo-tab-btn').forEach(b => b.classList.remove('is-active'))
      tabs.querySelectorAll('.demo-tab-panel').forEach(p => p.classList.remove('is-active'))
      btn.classList.add('is-active')
      tabs.querySelector(`[data-panel="${id}"]`)?.classList.add('is-active')
    })
  })
})
</script>
