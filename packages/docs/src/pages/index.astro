---
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
---
<BaseLayout title="SliderKit — A modern, accessible slider library for the web">
  <SiteHeader />
  <main class="landing">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Open source · MIT · TypeScript
        </div>
        <h1 class="hero-title">
          Build sliders<br />
          <span class="hero-accent">that actually work.</span>
        </h1>
        <p class="hero-subtitle">
          SliderKit is a modular, accessible slider engine with a lean core,
          tree-shakeable plugins, CSS effects, and WebGL renderer.
          Zero dependencies. Fully typed.
        </p>
        <div class="hero-actions">
          <a href="/docs/getting-started" class="btn btn-primary">Get started →</a>
          <a href="/demos/base" class="btn btn-ghost">View demos</a>
          <a href="https://github.com/andresclua/sliderkit" target="_blank" rel="noopener" class="btn btn-ghost btn-github">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
        </div>
        <div class="hero-install">
          <code>pnpm add @andresclua/sliderkit @andresclua/sliderkit-plugins</code>
        </div>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>~4 KB</strong><span>core (gzip)</span></div>
        <div class="stat-sep"></div>
        <div class="stat"><strong>13+</strong><span>plugins</span></div>
        <div class="stat-sep"></div>
        <div class="stat"><strong>6</strong><span>CSS effects</span></div>
        <div class="stat-sep"></div>
        <div class="stat"><strong>4</strong><span>WebGL shaders</span></div>
      </div>
    </section>

    <!-- Feature grid -->
    <section class="features">
      <div class="section-inner">
        <header class="section-header">
          <h2>Everything you need, nothing you don't</h2>
          <p>Start with the core. Add what you need. Tree-shake the rest.</p>
        </header>
        <div class="feature-grid">
          {[
            { icon: '⚡', title: 'Lightweight core', desc: 'The engine is tiny. Import only what you use — plugins, effects and WebGL are fully optional extras.' },
            { icon: '♿', title: 'Fully accessible', desc: 'ARIA roles, live regions, roledescription, keyboard navigation, and prefers-reduced-motion out of the box.' },
            { icon: '🎨', title: '6 CSS effects', desc: 'Fade, cube, coverflow, flip, cards, creative — all pure CSS, no JavaScript animations required.' },
            { icon: '✨', title: 'WebGL renderer', desc: 'Powered by OGL. Displacement maps, RGB shift, pixel dissolve, parallax depth, and custom GLSL shaders.' },
            { icon: '🔌', title: '12 plugins', desc: 'Autoplay, arrows, pagination, thumbnails, mousewheel, lazy load, virtual slides, and more.' },
            { icon: '📱', title: 'Touch & drag', desc: 'Native-feeling swipe gestures with configurable threshold, angle, and resistance on touch and mouse.' },
            { icon: '📐', title: 'Responsive', desc: 'Change any option at any viewport width. ResizeObserver powered — no window resize hacks.' },
            { icon: '🔒', title: 'TypeScript strict', desc: 'Fully typed API, typed event payloads, typed plugin interface. No any escape hatches anywhere.' },
          ].map(f => (
            <div class="feature-card">
              <span class="feature-icon">{f.icon}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Code preview -->
    <section class="code-preview">
      <div class="code-preview-inner">
        <div class="code-preview-text">
          <h2>Up and running<br />in seconds</h2>
          <p>Drop in the markup, pass options, done. Full plugin composition with type-safe callbacks, no boilerplate.</p>
          <div class="code-links">
            <a href="/docs/getting-started" class="btn btn-primary-dark">Read the docs →</a>
            <a href="/demos/base" class="btn btn-outline-dark">Browse demos</a>
          </div>
        </div>
        <div class="code-preview-code">
          <div class="code-window">
            <div class="code-window-bar">
              <span class="dot dot-r"></span>
              <span class="dot dot-y"></span>
              <span class="dot dot-g"></span>
              <span class="code-window-title">slider.ts</span>
            </div>
            <pre class="code-window-body"><code>{`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay }
  from '@andresclua/sliderkit-plugins'

const slider = new Slider('#hero-slider', {
  slidesPerPage: 1,
  loop: true,
  speed: 420,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
  on: {
    afterSlideChange: ({ index }) => {
      console.log('Slide:', index)
    },
  },
})`}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Packages -->
    <section class="packages">
      <div class="section-inner">
        <header class="section-header">
          <h2>One ecosystem, four packages</h2>
          <p>Import only what your project needs. Everything is tree-shaken by default.</p>
        </header>
        <div class="package-grid">
          {[
            { name: '@andresclua/sliderkit', badge: 'Core', color: '#6C2BD9', bg: '#ede9fe', desc: 'The slider engine. Touch, drag, keyboard, infinite loop, breakpoints, a11y, events, and plugin system.' },
            { name: '@andresclua/sliderkit-plugins', badge: 'Plugins', color: '#2563EB', bg: '#dbeafe', desc: '12 UI plugins. Arrows, pagination, autoplay, thumbnails, mousewheel, lazy load, and more.' },
            { name: '@andresclua/sliderkit-effects', badge: 'Effects', color: '#059669', bg: '#d1fae5', desc: '6 CSS transition effects. Fade, cube, coverflow, flip, cards, and creative — zero JS animations.' },
            { name: '@andresclua/sliderkit-webgl', badge: 'WebGL', color: '#D97706', bg: '#fef3c7', desc: 'OGL-powered WebGL renderer. 4 built-in shader effects plus a custom GLSL API with automatic fallback.' },
          ].map(p => (
            <div class="package-card">
              <div class="package-top" style={`background: ${p.bg}`}></div>
              <div class="package-body">
                <span class="package-badge" style={`color: ${p.color}`}>{p.badge}</span>
                <code class="package-name" style={`color: ${p.color}`}>{p.name}</code>
                <p>{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA / Sponsor -->
    <section class="cta">
      <div class="cta-inner">
        <h2>Free, open source, and yours to use.</h2>
        <p>SliderKit is MIT-licensed. If it saves you time, consider sponsoring on GitHub Sponsors and help keep it maintained.</p>
        <div class="cta-actions">
          <a href="/docs/getting-started" class="btn btn-primary-dark">Get started</a>
          <a href="https://github.com/sponsors/andresclua" target="_blank" rel="noopener" class="btn btn-sponsor">♥ Sponsor</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
.landing { padding-top: var(--header-h); }

/* ── Hero ─────────────────────────────────────────────────────────────────── */
.hero {
  background: #0f0f17;
  color: #fff;
  padding: 5rem 1.5rem 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(108,43,217,0.45) 0%, transparent 70%);
  pointer-events: none;
}
.hero-inner { max-width: 760px; margin: 0 auto; position: relative; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #a78bfa;
  border: 1px solid rgba(167,139,250,0.3);
  border-radius: 99px;
  padding: 5px 14px;
  margin-bottom: 1.75rem;
}
.hero-badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #a78bfa;
  animation: pulse-dot 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(0.75); }
}

.hero-title {
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.04em;
  margin-bottom: 1.25rem;
}
.hero-accent {
  background: linear-gradient(90deg, #c4b5fd 0%, #818cf8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: 1.05rem;
  color: #94a3b8;
  line-height: 1.65;
  max-width: 580px;
  margin: 0 auto 2rem;
}

.hero-actions {
  display: flex;
  gap: 0.6rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.hero-install { margin-bottom: 3rem; }
.hero-install code {
  display: inline-block;
  background: rgba(255,255,255,0.07);
  color: #c7d2fe;
  border: 1px solid rgba(255,255,255,0.1);
  padding: 9px 18px;
  border-radius: 8px;
  font-size: 0.82rem;
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.04);
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 1.1rem 1.5rem;
  margin: 0 -1.5rem;
  flex-wrap: wrap;
  gap: 0;
}
.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0.5rem 2.5rem;
}
.stat strong { font-size: 1.25rem; font-weight: 800; color: #e2e8f0; }
.stat span   { font-size: 0.72rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 2px; }
.stat-sep    { width: 1px; height: 2rem; background: rgba(255,255,255,0.1); }

/* ── Buttons ──────────────────────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.15s;
  white-space: nowrap;
}
.btn-primary { background: #fff; color: #1e1b4b; }
.btn-primary:hover { background: #e2e8f0; text-decoration: none; }
.btn-ghost {
  background: rgba(255,255,255,0.08);
  color: #cbd5e1;
  border: 1px solid rgba(255,255,255,0.14);
}
.btn-ghost:hover { background: rgba(255,255,255,0.14); color: #fff; text-decoration: none; }

.btn-primary-dark { background: var(--brand); color: #fff; }
.btn-primary-dark:hover { background: var(--brand-dark); text-decoration: none; }
.btn-outline-dark {
  background: transparent;
  color: var(--text-muted);
  border: 1px solid var(--border);
}
.btn-outline-dark:hover { background: var(--bg); color: var(--text); text-decoration: none; }
.btn-sponsor { background: #fce7f3; color: #be185d; border: 1px solid #fbcfe8; }
.btn-sponsor:hover { background: #fbcfe8; text-decoration: none; }

/* ── Section shared ───────────────────────────────────────────────────────── */
.section-inner { max-width: 1100px; margin: 0 auto; }
.section-header { text-align: center; margin-bottom: 2.5rem; }
.section-header h2 { font-size: 1.85rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
.section-header p  { font-size: 1rem; color: var(--text-muted); }

/* ── Features ─────────────────────────────────────────────────────────────── */
.features { padding: 5rem 1.5rem; background: var(--bg); }
.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
  gap: 1rem;
}
.feature-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem 1.1rem;
  transition: box-shadow 0.15s;
}
.feature-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
.feature-icon { font-size: 1.4rem; display: block; margin-bottom: 0.6rem; }
.feature-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.35rem; }
.feature-card p  { font-size: 0.82rem; color: var(--text-muted); line-height: 1.55; margin: 0; }

/* ── Code preview ─────────────────────────────────────────────────────────── */
.code-preview {
  background: #0f0f17;
  padding: 5rem 1.5rem;
}
.code-preview-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
@media (max-width: 760px) {
  .code-preview-inner { grid-template-columns: 1fr; gap: 2rem; }
}
.code-preview-text { color: #e2e8f0; }
.code-preview-text h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.03em;
  margin-bottom: 0.75rem;
}
.code-preview-text p { font-size: 0.95rem; color: #94a3b8; line-height: 1.65; margin-bottom: 1.75rem; }
.code-links { display: flex; gap: 0.6rem; flex-wrap: wrap; }

.code-window {
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.code-window-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  background: #1a1a2e;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.dot { width: 11px; height: 11px; border-radius: 50%; }
.dot-r { background: #ff5f57; }
.dot-y { background: #febc2e; }
.dot-g { background: #28c840; }
.code-window-title { margin-left: auto; font-size: 0.72rem; color: #64748b; }
.code-window-body {
  margin: 0;
  padding: 1.25rem 1.5rem;
  background: #12121e;
  border-radius: 0;
  font-size: 0.8rem;
  line-height: 1.7;
  overflow-x: auto;
}
.code-window-body code { color: #c4b5fd; }

/* ── Packages ─────────────────────────────────────────────────────────────── */
.packages {
  padding: 5rem 1.5rem;
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.package-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}
.package-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: box-shadow 0.15s;
}
.package-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
.package-top { height: 5px; }
.package-body { padding: 1.25rem; }
.package-badge {
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: block;
  margin-bottom: 0.4rem;
}
.package-name {
  font-size: 0.78rem;
  font-weight: 700;
  display: block;
  margin-bottom: 0.6rem;
  word-break: break-all;
}
.package-card p { font-size: 0.83rem; color: var(--text-muted); line-height: 1.55; margin: 0; }

/* ── CTA ──────────────────────────────────────────────────────────────────── */
.cta { padding: 5rem 1.5rem; text-align: center; background: var(--bg); }
.cta-inner { max-width: 600px; margin: 0 auto; }
.cta-inner h2 { font-size: 1.85rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.75rem; }
.cta-inner p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 2rem; }
.cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
</style>
