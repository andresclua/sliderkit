---
import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Progress Bar Plugin">
  <h1>Progress Bar</h1>
  <p class="lead">A thin bar that fills proportionally as you advance through slides. The fill width is derived from the slider's <code>progress</code> value (0–1) and updates on every slide change.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} progressBar {"}"} from '@andresclua/sliderkit-plugins'</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>el</code></td><td><code>string | HTMLElement</code></td><td>—</td><td>Target track container. Auto-created with class <code>c--slider-a__progress</code> if omitted.</td></tr>
    </tbody>
  </table>

  <h2>CSS classes</h2>
  <table>
    <thead><tr><th>Class</th><th>Element</th></tr></thead>
    <tbody>
      <tr><td><code>.c--slider-a__progress</code></td><td>Track container</td></tr>
      <tr><td><code>.c--slider-a__progress-fill</code></td><td>Fill element (width is animated)</td></tr>
    </tbody>
  </table>

  <h2>Example</h2>
  <pre><code>{`import { createSlider } from '@andresclua/sliderkit'
import { progressBar } from '@andresclua/sliderkit-plugins'

createSlider('#my-slider', {
  loop: false,
  plugins: [progressBar({ el: '.my-progress-track' })],
})`}</code></pre>

  <p><a href="/demos/progress-bar">View progress bar demo</a></p>
</DocsLayout>
