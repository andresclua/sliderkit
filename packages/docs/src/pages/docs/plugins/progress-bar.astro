---
import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Progress Bar Plugin">
  <h1>progressBar</h1>
  <p class="lead">A thin bar that fills proportionally as you advance through slides. Distinct from the <code>pagination</code> progress type — this renders an absolute-position bar at the top or bottom.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} progressBar {"}"} from '@andresclua/sliderkit-plugins'</code></pre>

  <h2>Usage</h2>
  <pre><code>{`new Slider('#el', {
  loop: false,
  plugins: [progressBar()],
})`}</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>el</code></td><td><code>string | HTMLElement</code></td><td>—</td><td>Target container. Auto-created after slider if omitted.</td></tr>
    </tbody>
  </table>

  <h2>CSS classes</h2>
  <table>
    <thead><tr><th>Class</th><th>Element</th></tr></thead>
    <tbody>
      <tr><td><code>.c--slider-a__progress</code></td><td>Track bar container</td></tr>
      <tr><td><code>.c--slider-a__progress-fill</code></td><td>Fill element (width animated)</td></tr>
    </tbody>
  </table>

  <h2>Demo</h2>
  <p><a href="/demos/progress-bar">View progress bar demo →</a></p>
</DocsLayout>
