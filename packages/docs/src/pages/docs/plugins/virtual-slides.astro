import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Virtual Slides Plugin">
  <h1>Virtual Slides</h1>
  <p class="lead">Renders only the active slide plus a configurable number of surrounding slides, deferring asset loading for all others. Ideal for sliders with many image-heavy slides.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} virtualSlides {"}"} from '@andresclua/sliderkit-plugins'</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>preRender</code></td><td><code>number</code></td><td><code>2</code></td><td>Number of slides to pre-render on each side of the active slide.</td></tr>
      <tr><td><code>cache</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Skip re-rendering slides that have already been loaded once.</td></tr>
      <tr><td><code>renderSlide</code></td><td><code>(index: number) =&gt; HTMLElement</code></td><td>—</td><td>Optional factory for custom slide element creation. Reserved for future use.</td></tr>
    </tbody>
  </table>

  <h2>How it works</h2>
  <p>Slides use <code>data-src</code> as a deferred content marker. The plugin reads it and injects the real image <code>src</code> (or <code>background-image</code>) when the slide enters the render window, then removes <code>data-src</code>.</p>

  <h2>Example</h2>
  <pre><code>{`<!-- HTML -->
<div id="my-slider">
  <div class="slide"><img data-src="/heavy-1.jpg" alt="..." /></div>
  <div class="slide"><img data-src="/heavy-2.jpg" alt="..." /></div>
  <!-- ... many more slides -->
</div>

<!-- JS -->
import { createSlider } from '@andresclua/sliderkit'
import { virtualSlides } from '@andresclua/sliderkit-plugins'

createSlider('#my-slider', {
  plugins: [virtualSlides({ preRender: 2, cache: true })],
})`}</code></pre>

  <p><a href="/demos/virtual-slides">View virtual slides demo</a></p>
</DocsLayout>
