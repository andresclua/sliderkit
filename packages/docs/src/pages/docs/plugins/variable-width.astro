---
import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Variable Width Plugin">
  <h1>Variable Width</h1>
  <p class="lead">Allows slides to retain their natural intrinsic width instead of being stretched to a uniform size. The wrapper is set to <code>max-content</code> width so slides line up side-by-side at their own dimensions.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} variableWidth {"}"} from '@andresclua/sliderkit-plugins'</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>adaptiveHeight</code></td><td><code>boolean</code></td><td>—</td><td>Reserved option — accepted by the interface but not yet implemented. Combine with the <code>autoHeight</code> plugin for height adaptation.</td></tr>
    </tbody>
  </table>

  <h2>How it works</h2>
  <p>Each slide has <code>flex-shrink: 0</code> applied and its <code>width</code> cleared so the browser uses its natural content width. The wrapper <code>width</code> is set to <code>max-content</code>. All inline styles are removed on destroy.</p>

  <h2>Example</h2>
  <pre><code>{`<!-- Slides keep their own widths -->
<div id="my-slider">
  <div class="slide" style="width: 200px">Narrow</div>
  <div class="slide" style="width: 400px">Wide</div>
  <div class="slide" style="width: 300px">Medium</div>
</div>

import { createSlider } from '@andresclua/sliderkit'
import { variableWidth } from '@andresclua/sliderkit-plugins'

createSlider('#my-slider', {
  plugins: [variableWidth()],
})`}</code></pre>
</DocsLayout>
