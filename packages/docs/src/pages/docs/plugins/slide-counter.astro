---
import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Slide Counter Plugin">
  <h1>slideCounter</h1>
  <p class="lead">Overlay badge showing "2 / 5" in a corner of the slider. Useful for galleries.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} slideCounter {"}"} from '@acslider/plugins'</code></pre>

  <h2>Usage</h2>
  <pre><code>{`new Slider('#el', {
  plugins: [
    slideCounter({
      template: ({ current, total }) => \`\${current} / \${total}\`,
    }),
  ],
})`}</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>el</code></td><td><code>string | HTMLElement</code></td><td>—</td><td>Target element. Auto-created inside container if omitted.</td></tr>
      <tr><td><code>template</code></td><td><code>{"({"} current, total {"}"}) => string</code></td><td><code>'current / total'</code></td><td>Custom format function.</td></tr>
    </tbody>
  </table>

  <h2>Demo</h2>
  <p><a href="/demos/slide-counter">View slide counter demo →</a></p>
</DocsLayout>
