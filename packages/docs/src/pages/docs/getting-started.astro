import DocsLayout from '../../layouts/DocsLayout.astro'
---
<DocsLayout title="Getting Started">
  <h1>Getting Started</h1>
  <p class="lead">SliderKit is a lightweight, accessible carousel library written in TypeScript. The core handles all sliding logic; plugins add arrows, pagination, and more.</p>

  <h2>Installation</h2>
  <pre><code>npm install @andresclua/sliderkit @andresclua/sliderkit-plugins
# or
pnpm add @andresclua/sliderkit @andresclua/sliderkit-plugins</code></pre>

  <h2>HTML</h2>
  <p>Give your slider container an <code>id</code>. Drop your slides directly inside — no extra wrapper needed.</p>
  <pre><code>&lt;div id="my-slider"&gt;
  &lt;div&gt;Slide 1&lt;/div&gt;
  &lt;div&gt;Slide 2&lt;/div&gt;
  &lt;div&gt;Slide 3&lt;/div&gt;
&lt;/div&gt;</code></pre>

  <h2>Required CSS</h2>
  <p>The slider injects layout styles at runtime. You need to provide the structural rules:</p>
  <pre><code>/* clip the sliding track */
.c--slider-a__overflow {"{"} overflow: hidden; {"}"}

/* horizontal carousel — added automatically by the JS */
.c--slider-a--horizontal {"{"} white-space: nowrap; {"}"}
.c--slider-a--horizontal > .c--slider-a__item {"{"} display: inline-block; vertical-align: top; {"}"}</code></pre>
  <p>All demo pages include a complete stylesheet reference in their CSS tab.</p>

  <h2>Basic usage</h2>
  <pre><code>import {"{"} Slider {"}"} from '@andresclua/sliderkit'

new Slider('#my-slider', {"{"} items: 1, loop: true, speed: 300 {"}"})</code></pre>

  <h2>With plugins</h2>
  <pre><code>import {"{"} Slider {"}"} from '@andresclua/sliderkit'
import {"{"} arrows, pagination {"}"} from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {"{"}
  items: 1,
  loop:  true,
  speed: 300,
  plugins: [
    arrows(),
    pagination({"{"} type: 'dots', clickable: true {"}"}),
  ],
{"}"})</code></pre>

