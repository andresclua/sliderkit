import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Flip Effect">
  <h1>Flip Effect</h1>
  <p class="lead">Rotates slides around the Y axis like a page turn. Each slide sits at a <code>rotateY</code> offset from the active one — 0°, ±180°, ±360°, etc. — with <code>backface-visibility: hidden</code> so reverse sides are invisible.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} flipEffect {"}"} from '@andresclua/sliderkit-effects'</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>slideShadows</code></td><td><code>boolean</code></td><td>—</td><td>Reserved for a future drop-shadow layer.</td></tr>
      <tr><td><code>limitRotation</code></td><td><code>boolean</code></td><td>—</td><td>Reserved option — not yet implemented.</td></tr>
    </tbody>
  </table>

  <h2>How it works</h2>
  <p>On install the plugin:</p>
  <ul>
    <li>Enables <code>preserve-3d</code> and <code>perspective: 1200px</code> on the wrapper</li>
    <li>Positions all slides <code>absolute</code> at <code>top: 0 / left: 0 / width: 100%</code></li>
    <li>Sets <code>backface-visibility: hidden</code> on each slide</li>
    <li>Applies <code>rotateY(offset × 180deg)</code> where <code>offset = slideIndex - activeIndex</code></li>
  </ul>

  <h2>CSS class</h2>
  <p>The container receives <code>.c--slider-effect-flip</code> while the plugin is active.</p>

  <h2>Example</h2>
  <pre><code>{`import { createSlider } from '@andresclua/sliderkit'
import { flipEffect } from '@andresclua/sliderkit-effects'
import { arrows } from '@andresclua/sliderkit-plugins'

createSlider('#my-slider', {
  loop: true,
  plugins: [
    flipEffect(),
    arrows(),
  ],
})
`}</code></pre>

  <pre><code>{`/* CSS — animate the rotation */
.c--slider-effect-flip .c--slider-a__item {
  transition: transform 600ms ease;
}
`}</code></pre>

  <p><a href="/demos/effect-flip">View flip effect demo</a></p>
</DocsLayout>
