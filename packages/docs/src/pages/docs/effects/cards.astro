import DocsLayout from '../../../layouts/DocsLayout.astro'
---
<DocsLayout title="Cards Effect">
  <h1>Cards Effect</h1>
  <p class="lead">Stacks slides like a deck of playing cards. The active slide is on top; upcoming slides peek behind it with increasing vertical offset, scale-down, and optional rotation. Slides behind the active card are hidden.</p>

  <h2>Import</h2>
  <pre><code>import {"{"} cardsEffect {"}"} from '@andresclua/sliderkit-effects'</code></pre>

  <h2>Options</h2>
  <table>
    <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>perSlideOffset</code></td><td><code>number</code></td><td><code>8</code></td><td>Vertical pixel offset per card in the stack behind the active slide.</td></tr>
      <tr><td><code>perSlideRotate</code></td><td><code>number</code></td><td><code>2</code></td><td>Degrees of Z rotation per card in the stack.</td></tr>
      <tr><td><code>rotate</code></td><td><code>boolean</code></td><td>—</td><td>Reserved option for toggling rotation on/off.</td></tr>
      <tr><td><code>slideShadows</code></td><td><code>boolean</code></td><td>—</td><td>Reserved for per-card shadow overlays.</td></tr>
    </tbody>
  </table>

  <h2>How it works</h2>
  <p>For each slide at distance <code>offset</code> ahead of the active one:</p>
  <pre><code>{`translateY(offset * perSlideOffset px)
scale(1 - offset * 0.05)
rotate(offset * perSlideRotate deg)
z-index: 100 - offset`}</code></pre>
  <p>Slides behind the active card (<code>offset &lt; 0</code>) are hidden with <code>display: none</code>.</p>

  <h2>CSS class</h2>
  <p>The container receives <code>.c--slider-effect-cards</code> while the plugin is active.</p>

  <h2>Example</h2>
  <pre><code>{`import { createSlider } from '@andresclua/sliderkit'
import { cardsEffect } from '@andresclua/sliderkit-effects'
import { arrows } from '@andresclua/sliderkit-plugins'

createSlider('#my-slider', {
  loop: false,
  plugins: [
    cardsEffect({ perSlideOffset: 8, perSlideRotate: 2 }),
    arrows(),
  ],
})
`}</code></pre>

  <pre><code>{`/* CSS — animate the deck */
.c--slider-effect-cards .c--slider-a__item {
  transition: transform 400ms ease;
}
`}</code></pre>

  <p><a href="/demos/effect-cards">View cards effect demo</a></p>
</DocsLayout>
