---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Pagination — Fraction">

  <DemoViewer
    title="Fraction — 1 slide per page"
    description='Standard "2 / 5" counter. Each step advances one slide.'
    code={`pagination({ type: 'fraction' })`}
  >
    <div class="c--slider-a" id="demo-pag-frac">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
        <div class="c--slider-a__slide demo-slide s-pink"   data-slide>6</div>
      </div>
    </div>
    <div id="demo-pag-frac-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="Fraction — 2 slides per page"
    description='With slidesPerPage: 2 the fraction advances in pages: "1 / 3", "2 / 3", "3 / 3".'
    code={`new Slider('#el', {
  slidesPerPage: 2,
  gutter: 16,
  plugins: [
    arrows(),
    pagination({ type: 'fraction' }),
  ],
})`}
  >
    <div class="c--slider-a" id="demo-pag-frac2">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
        <div class="c--slider-a__slide demo-slide s-pink"   data-slide>6</div>
      </div>
    </div>
    <div id="demo-pag-frac2-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

</DemoLayout>

<script>
import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'

new Slider('#demo-pag-frac', {
  loop: false,
  rewind: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-pag-frac-pag', type: 'fraction' }),
  ],
})

new Slider('#demo-pag-frac2', {
  slidesPerPage: 2,
  gutter: 16,
  loop: false,
  rewind: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-pag-frac2-pag', type: 'fraction' }),
  ],
})
</script>
