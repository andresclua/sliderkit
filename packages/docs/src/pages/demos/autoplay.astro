---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Autoplay">
  <DemoViewer
    title="Autoplay"
    description="autoplay() advances the slider every 3 s. Hover to pause, move the mouse away to resume."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`.demo-slide { height: 260px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  loop: true,
  speed: 500,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})`}
  >
    <div id="demo-autoplay">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>

  <DemoViewer
    title="Autoplay — progress bar"
    description="Combine autoplay with pagination type:'progress' to show a visual countdown between slides."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`.demo-slide { height: 260px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; }
.c--slider-a__pagination-progress { height: 4px; background: rgba(255,255,255,0.3); }
.c--slider-a__pagination-progress-fill { background: #fff; transition: width 2800ms linear; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  loop: true,
  speed: 500,
  plugins: [
    arrows(),
    pagination({ type: 'progress' }),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})`}
  >
    <div id="demo-autoplay-progress">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay } from '@andresclua/sliderkit-plugins'

new Slider('#demo-autoplay', {
  items: 1,
  loop: true,
  speed: 500,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})

new Slider('#demo-autoplay-progress', {
  items: 1,
  loop: true,
  speed: 500,
  plugins: [
    arrows(),
    pagination({ type: 'progress' }),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})
</script>
