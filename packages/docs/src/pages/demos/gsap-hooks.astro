<style>
/* Hero slider */
#demo-hero {
  position: relative;
  overflow: hidden;
  border-radius: 8px;
}
#demo-hero .c--slider-a__wrapper { will-change: transform; }
#demo-hero .hs-slide {
  flex-shrink: 0;
  width: 100%;
  height: 360px;
  background-size: cover;
  background-position: center;
  position: relative;
}
#demo-hero .hs-slide::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.08) 60%);
}
#demo-hero .hs-content {
  position: absolute;
  bottom: 36px; left: 36px; right: 36px;
  z-index: 2;
  color: #fff;
}
#demo-hero .hs-tag {
  display: inline-block;
  font-size: 0.68rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  background: rgba(108,43,217,0.85);
  padding: 3px 10px; border-radius: 99px;
  margin-bottom: 10px;
}
#demo-hero .hs-title {
  font-size: clamp(1.3rem, 3vw, 1.9rem);
  font-weight: 700; line-height: 1.2;
  margin-bottom: 6px;
}
#demo-hero .hs-desc {
  font-size: 0.9rem; opacity: 0.85; max-width: 460px;
}
#demo-hero .c--slider-a__arrow {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(4px);
  color: #fff;
}

/* Card slider */
#demo-cards-gsap {
  position: relative;
  overflow: hidden;
  background: #f3f4f6;
  border-radius: 8px;
}
#demo-cards-gsap .card-slide { padding: 8px; }
#demo-cards-gsap .card-body {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 28px 24px 24px;
  height: 220px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
#demo-cards-gsap .card-icon  { font-size: 2rem; line-height: 1; }
#demo-cards-gsap .card-title { font-size: 1.1rem; font-weight: 700; color: #111827; margin: 0; }
#demo-cards-gsap .card-text  { font-size: 0.875rem; color: #6b7280; line-height: 1.5; flex: 1; margin: 0; }
#demo-cards-gsap .card-badge {
  display: inline-block; align-self: flex-start;
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  background: #ede9fe; color: #6C2BD9;
  padding: 2px 10px; border-radius: 99px;
}
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'
import { gsap } from 'gsap'

// ── Demo 1: Hero slider with text animation ───────────────────────────────────
const heroSlider = new Slider('#demo-hero', {
  loop: true,
  speed: 600,
  plugins: [
    arrows(),
    pagination({ el: '#demo-hero-pag', type: 'dots', clickable: true }),
  ],
})

const heroContents = [...heroSlider.slides].map(s => s.querySelector('.hs-content'))

// Animate first slide in on load
gsap.fromTo(heroContents[0]?.children ?? [],
  { y: 30, opacity: 0 },
  { y: 0, opacity: 1, duration: 0.6, stagger: 0.1, ease: 'power3.out', delay: 0.3 }
)

heroSlider.on('beforeSlideChange', ({ index }: { index: number }) => {
  const el = heroContents[index]
  if (!el) return
  gsap.to(el.children, { y: -20, opacity: 0, duration: 0.22, stagger: 0.05, ease: 'power2.in' })
})

heroSlider.on('afterSlideChange', ({ index }: { index: number }) => {
  const el = heroContents[index]
  if (!el) return
  gsap.fromTo(el.children,
    { y: 36, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.55, stagger: 0.09, ease: 'power3.out' }
  )
})

// ── Demo 2: Staggered card entrance ───────────────────────────────────────────
const cardSlider = new Slider('#demo-cards-gsap', {
  slidesPerPage: 3,
  gutter: 0,
  loop: true,
  speed: 400,
  plugins: [
    arrows(),
    pagination({ el: '#demo-cards-gsap-pag', type: 'dots', clickable: true }),
  ],
})

const cardBodies = [...cardSlider.slides].map(s => s.querySelector('.card-body'))

function animateCardIn(index: number) {
  const card = cardBodies[index % cardBodies.length]
  if (!card) return
  gsap.fromTo(card.children,
    { y: 24, opacity: 0 },
    { y: 0, opacity: 1, duration: 0.45, stagger: 0.08, ease: 'power3.out' }
  )
}

// Animate initial visible cards
const initInfo = cardSlider.getInfo()
for (let i = 0; i < initInfo.slidesPerPage; i++) {
  animateCardIn(i)
}

// Track direction so afterSlideChange knows which side cards enter from
let cardDir: 'next' | 'prev' = 'next'
cardSlider.on('beforeSlideChange', ({ direction }: { direction: 'next' | 'prev' }) => {
  cardDir = direction
})

cardSlider.on('afterSlideChange', ({ index, previousIndex }: { index: number; previousIndex: number }) => {
  const spp  = cardSlider.getInfo().slidesPerPage as number
  const n    = cardBodies.length
  const newSlides: number[] = []

  if (cardDir === 'next') {
    // Cards entering from the right: those in the new range beyond the old range
    for (let i = Math.max(index, previousIndex + spp); i < index + spp; i++) {
      newSlides.push(i % n)
    }
  } else {
    // Cards entering from the left: those in the new range before the old range started
    for (let i = index; i <= Math.min(index + spp - 1, previousIndex - 1); i++) {
      newSlides.push(i % n)
    }
  }

  // Fallback for loop boundary jumps (no overlap between old and new range)
  if (newSlides.length === 0) {
    for (let i = 0; i < spp; i++) newSlides.push((index + i) % n)
  }

  newSlides.forEach(animateCardIn)
})
</script>
