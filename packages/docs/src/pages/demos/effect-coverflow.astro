---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Effect — Coverflow">

  <DemoViewer
    title="iTunes-style coverflow"
    description="Adjacent slides are visible and rotated in 3D, creating the classic album-art coverflow look. Use slidesPerPage: 3 (or more) so the neighbours peek from the sides — that's what makes the effect work. The rotate option controls the Y-axis angle of the side cards, and depth pushes them back on the Z axis."
    html={`<div class="c--slider-a c--slider-a--coverflow" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3</div>
    <div class="c--slider-a__slide">4</div>
    <div class="c--slider-a__slide">5</div>
    <div class="c--slider-a__slide">6</div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__slide { flex-shrink: 0; height: 220px; }

/* Coverflow: show sides, don't clip them */
.c--slider-a--coverflow { overflow: visible; background: transparent; }
.c--slider-a--coverflow .c--slider-a__slide { transition: transform 0.4s ease; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { coverflowEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  slidesPerPage: 3,
  gutter: 20,
  loop: true,
  speed: 400,
  plugins: [
    coverflowEffect({ rotate: 50, depth: 100, modifier: 1 }),
    arrows(),
    pagination({ el: '#my-pag', type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--coverflow" id="demo-coverflow">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
        <div class="c--slider-a__slide demo-slide s-pink"   data-slide>6</div>
      </div>
    </div>
    <div id="demo-coverflow-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="Subtle coverflow (low rotate)"
    description="Lower the rotate value (e.g. 25) for a softer, more modern feel — side cards angle gently instead of fully turning. Combine with edgePadding so the very edges of neighbouring slides peek in, hinting that there's more content to explore."
    html={`<div class="c--slider-a c--slider-a--coverflow" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3</div>
    <div class="c--slider-a__slide">4</div>
    <div class="c--slider-a__slide">5</div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__slide { flex-shrink: 0; height: 220px; }

.c--slider-a--coverflow { overflow: visible; background: transparent; }
.c--slider-a--coverflow .c--slider-a__slide { transition: transform 0.5s ease; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { coverflowEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  slidesPerPage: 2,
  edgePadding: 60,
  gutter: 16,
  loop: true,
  speed: 500,
  plugins: [
    coverflowEffect({ rotate: 25, depth: 60, modifier: 1 }),
    arrows(),
    pagination({ el: '#my-pag', type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--coverflow" id="demo-coverflow-soft">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-coverflow-soft-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

</DemoLayout>

<style>
.c--slider-a--coverflow { overflow: visible; background: transparent; }
.c--slider-a--coverflow .c--slider-a__slide { transition: transform 0.4s ease; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { coverflowEffect } from '@andresclua/sliderkit-effects'

new Slider('#demo-coverflow', {
  slidesPerPage: 3,
  gutter: 20,
  loop: true,
  speed: 400,
  plugins: [
    coverflowEffect({ rotate: 50, depth: 100, modifier: 1 }),
    arrows(),
    pagination({ el: '#demo-coverflow-pag', type: 'dots', clickable: true }),
  ],
})

new Slider('#demo-coverflow-soft', {
  slidesPerPage: 2,
  edgePadding: 60,
  gutter: 16,
  loop: true,
  speed: 500,
  plugins: [
    coverflowEffect({ rotate: 25, depth: 60, modifier: 1 }),
    arrows(),
    pagination({ el: '#demo-coverflow-soft-pag', type: 'dots', clickable: true }),
  ],
})
</script>
