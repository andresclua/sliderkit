---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Effect — Coverflow">
  <DemoViewer
    title="CSS Effect — Coverflow"
    description="iTunes-style coverflow with 3D rotation and depth. Uses CSS perspective."
    code={`import { coverflowEffect } from '@acslider/effects'

new Slider('#el', {
  slidesPerPage: 3,
  edgePadding: 40,
  loop: true,
  plugins: [
    coverflowEffect({ rotate: 50, depth: 100 }),
    arrows(),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--coverflow" id="demo-coverflow">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
        <div class="c--slider-a__slide demo-slide s-pink"   data-slide>6</div>
      </div>
    </div>
    <div id="demo-coverflow-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>
</DemoLayout>

<style>
.c--slider-a--coverflow { overflow: visible; background: transparent; }
.c--slider-a--coverflow .c--slider-a__slide { transition: transform 0.4s ease; }
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'
import { coverflowEffect } from '@acslider/effects'

new Slider('#demo-coverflow', {
  slidesPerPage: 3,
  gutter: 20,
  loop: true,
  speed: 400,
  plugins: [
    coverflowEffect({ rotate: 50, depth: 100, modifier: 1 }),
    arrows(),
    pagination({ el: '#demo-coverflow-pag', type: 'dots', clickable: true }),
  ],
})
</script>
