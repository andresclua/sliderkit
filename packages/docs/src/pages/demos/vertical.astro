---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Vertical">
  <DemoViewer
    title="Vertical slider"
    description='Set axis: "vertical" for a top-to-bottom slider. Swipe up/down or use the arrows to navigate.'
    html={`<div id="my-slider" style="height: 300px;">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`/* Vertical mode: the track element needs an explicit height */
#my-slider { height: 300px; }

.c--slider-a__item { height: 300px; }

.c--slider-a__arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10; width: 40px; height: 40px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.9); cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.c--slider-a__arrow--prev { left: 12px; }
.c--slider-a__arrow--next { right: 12px; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  axis: 'vertical',
  loop: true,
  speed: 300,
  plugins: [arrows()],
})`}
  >
    <div id="demo-vertical" style="height: 300px;">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#demo-vertical', {
  items: 1,
  axis: 'vertical',
  loop: true,
  speed: 300,
  plugins: [arrows()],
})
</script>
