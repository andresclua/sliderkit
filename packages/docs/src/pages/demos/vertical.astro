---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Vertical">
  <DemoViewer
    title="Vertical slider"
    description='Set axis:"vertical" for a top-to-bottom slider. Give the container a fixed height. Swipe up/down or use the arrows.'
    html={`<div id="my-slider" style="height:300px">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`#my-slider { height: 300px; }
.demo-slide { height: 300px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; }

/* vertical arrows: top / bottom instead of left / right */
.sliderkit__arrow {
  position: absolute;
  left: 50%; transform: translateX(-50%);
  z-index: 10; width: 40px; height: 40px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.9); cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.sliderkit__arrow--prev { top: 8px; }
.sliderkit__arrow--next { bottom: 8px; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  axis: 'vertical',
  loop: true,
  speed: 300,
  plugins: [arrows()],
})`}
  >
    <div id="demo-vertical" style="height:300px">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>
</DemoLayout>

<style>
#demo-vertical ~ :global(.sliderkit__outer) .sliderkit__arrow,
:global(#demo-vertical-ow) :global(.sliderkit__arrow) {
  left: 50%;
  transform: translateX(-50%);
  top: auto;
}
:global(#demo-vertical-ow) :global(.sliderkit__arrow--prev) { top: 8px; }
:global(#demo-vertical-ow) :global(.sliderkit__arrow--next) { bottom: 8px; top: auto; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#demo-vertical', {
  items: 1,
  axis: 'vertical',
  loop: true,
  speed: 300,
  plugins: [arrows()],
})
</script>
