---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Lazy Load">

  <DemoViewer
    title="Basic lazy load"
    description="Use data-src instead of src on images. The plugin swaps it to src only when the slide is about to enter the viewport. Open DevTools → Network → Img to see each request fire as you navigate."
    html={`<div class="c--slider-a" id="my-slider">
  <div class="c--slider-a__wrapper">
    <!-- First slide loads immediately (no data-src) -->
    <div class="c--slider-a__item img-slide" data-slide>
      <img src="/photos/01.jpg" alt="Slide 1" />
    </div>
    <!-- The rest are deferred -->
    <div class="c--slider-a__item img-slide" data-slide>
      <img data-src="/photos/02.jpg" alt="Slide 2" />
    </div>
    <div class="c--slider-a__item img-slide" data-slide>
      <img data-src="/photos/03.jpg" alt="Slide 3" />
    </div>
  </div>
</div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__item { flex-shrink: 0; width: 100%; }

.img-slide { height: 260px; position: relative; overflow: hidden; background: #e5e7eb; }
.img-slide img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, lazyLoad, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  loop: false,
  rewind: true,
  plugins: [
    lazyLoad({ rootMargin: '200px' }), // start loading 200px before the slide enters
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a" id="demo-lazy">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__item lazy-slide" data-slide>
          <img src="https://picsum.photos/seed/lz0/900/260" alt="Slide 1" class="lazy-img" />
        </div>
        <div class="c--slider-a__item lazy-slide" data-slide>
          <img data-src="https://picsum.photos/seed/lz1/900/260" alt="Slide 2" class="lazy-img" />
        </div>
        <div class="c--slider-a__item lazy-slide" data-slide>
          <img data-src="https://picsum.photos/seed/lz2/900/260" alt="Slide 3" class="lazy-img" />
        </div>
        <div class="c--slider-a__item lazy-slide" data-slide>
          <img data-src="https://picsum.photos/seed/lz3/900/260" alt="Slide 4" class="lazy-img" />
        </div>
        <div class="c--slider-a__item lazy-slide" data-slide>
          <img data-src="https://picsum.photos/seed/lz4/900/260" alt="Slide 5" class="lazy-img" />
        </div>
      </div>
    </div>
    <div id="demo-lazy-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="With loading placeholder"
    description="Show a skeleton or spinner while the image loads, then fade it in on load. The placeholder stays visible until the img load event fires — no flashing blank area."
    html={`<div class="c--slider-a" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__item img-slide" data-slide>
      <div class="skeleton"></div>
      <img data-src="/photo.jpg" alt="..." class="lazy-img" />
    </div>
    <!-- ...more slides -->
  </div>
</div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__item { flex-shrink: 0; width: 100%; }

.img-slide { height: 260px; position: relative; overflow: hidden; }

/* Skeleton shimmer shown until image loads */
.skeleton {
  position: absolute; inset: 0;
  background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
@keyframes shimmer { to { background-position: -200% 0; } }

.lazy-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  opacity: 0; transition: opacity 0.3s ease;
}
.lazy-img.loaded { opacity: 1; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, lazyLoad } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  loop: false,
  rewind: true,
  plugins: [
    lazyLoad({
      rootMargin: '300px',
      onLoad: (img) => img.classList.add('loaded'), // fade in on load
    }),
    arrows(),
  ],
})`}
  >
    <div class="c--slider-a" id="demo-lazy-skeleton">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__item lazy-skeleton-slide" data-slide>
          <div class="skeleton-bg"></div>
          <img data-src="https://picsum.photos/seed/sk0/900/260" alt="Slide 1" class="lazy-img-fade" />
        </div>
        <div class="c--slider-a__item lazy-skeleton-slide" data-slide>
          <div class="skeleton-bg"></div>
          <img data-src="https://picsum.photos/seed/sk1/900/260" alt="Slide 2" class="lazy-img-fade" />
        </div>
        <div class="c--slider-a__item lazy-skeleton-slide" data-slide>
          <div class="skeleton-bg"></div>
          <img data-src="https://picsum.photos/seed/sk2/900/260" alt="Slide 3" class="lazy-img-fade" />
        </div>
        <div class="c--slider-a__item lazy-skeleton-slide" data-slide>
          <div class="skeleton-bg"></div>
          <img data-src="https://picsum.photos/seed/sk3/900/260" alt="Slide 4" class="lazy-img-fade" />
        </div>
      </div>
    </div>
    <div id="demo-lazy-skeleton-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

</DemoLayout>

<style>
.lazy-slide { height: 260px; position: relative; overflow: hidden; background: #e5e7eb; }
.lazy-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

/* Skeleton demo */
.lazy-skeleton-slide { height: 260px; position: relative; overflow: hidden; }
.skeleton-bg {
  position: absolute; inset: 0;
  background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
@keyframes shimmer { to { background-position: -200% 0; } }
.lazy-img-fade {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  opacity: 0; transition: opacity 0.4s ease;
}
.lazy-img-fade.is-loaded { opacity: 1; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, lazyLoad, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#demo-lazy', {
  loop: false,
  rewind: true,
  plugins: [
    lazyLoad({ rootMargin: '200px' }),
    arrows(),
    pagination({ el: '#demo-lazy-pag', type: 'dots', clickable: true }),
  ],
})

new Slider('#demo-lazy-skeleton', {
  loop: false,
  rewind: true,
  plugins: [
    lazyLoad({
      rootMargin: '300px',
      onLoad: (img: HTMLImageElement) => img.classList.add('is-loaded'),
    }),
    arrows(),
    pagination({ el: '#demo-lazy-skeleton-pag', type: 'dots', clickable: true }),
  ],
})
</script>
