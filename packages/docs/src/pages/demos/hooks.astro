  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.7;
  margin-bottom: 16px;
}
.fade-title {
  font-size: 2.25rem;
  font-weight: 800;
  line-height: 1.15;
  margin: 0 0 16px;
}
.fade-sub {
  font-size: 1rem;
  opacity: 0.8;
  max-width: 380px;
  margin: 0;
  line-height: 1.6;
}

/* ── Hook cards (multi-item demo) ── */
.hc {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  overflow: hidden;
}
.hc__accent { height: 6px; }
.hc__body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.hc-num {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #9ca3af;
  text-transform: uppercase;
}
.hc-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: #111827;
  margin: 0;
  line-height: 1.3;
}
.hc-text {
  font-size: 0.875rem;
  color: #6b7280;
  margin: 0;
  line-height: 1.6;
}
.hc-cta {
  font-size: 0.8rem;
  font-weight: 600;
  color: #6C2BD9;
  text-decoration: none;
  margin-top: 4px;
}

/* ── Focus-center demo ── */
.focus-slide {
  height: 260px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3.5rem;
  font-weight: 800;
  color: #fff;
  border-radius: 12px;
  opacity: 0.5;
}
.sliderkit__item.focus-slide { display: inline-flex; }
</style>

<script>
import gsap from 'gsap'
import { Slider } from '@andresclua/sliderkit'
import type { SliderInstance } from '@andresclua/sliderkit'
import { arrows, pagination, hooks } from '@andresclua/sliderkit-plugins'
import { fadeEffect } from '@andresclua/sliderkit-effects'

const log = document.getElementById('demo-hooks-log') as HTMLElement | null

new Slider('#demo-hooks-basic', {
  items: 1,
  loop: true,
  speed: 300,
  plugins: [
    arrows(),
    hooks({
      onInit({ slides }) {
        if (log) log.textContent = 'onInit — ' + slides.length + ' slides ready'
      },
      beforeChange({ outgoing, incoming, direction }) {
        if (outgoing) (outgoing as HTMLElement).style.opacity = '0.3'
        if (log) log.textContent = 'beforeChange → ' + direction
      },
      afterChange({ slide }) {
        ;(slide as HTMLElement).style.opacity = '1'
        if (log) log.textContent = 'afterChange — now showing slide ' + (slide.textContent?.trim() ?? '')
      },
      onDragStart() { if (log) log.textContent = 'onDragStart' },
      onDragEnd()   { if (log) log.textContent = 'onDragEnd'   },
    }),
  ],
})

new Slider('#demo-hooks-gsap', {
  items: 1,
  loop: true,
  speed: 600,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
    fadeEffect({ duration: 600, easing: 'ease-in-out' }),
    hooks({
      onInit({ slides }) {
        gsap.from(slides[0].querySelectorAll('.fade-tag, .fade-title, .fade-sub'), {
          y: 28,
          autoAlpha: 0,
          stagger: 0.1,
          duration: 0.55,
          ease: 'power3.out',
          clearProps: 'all',
        })
      },
      beforeChange({ incoming }) {
        gsap.from((incoming as HTMLElement).querySelectorAll('.fade-tag, .fade-title, .fade-sub'), {
          y: 28,
          autoAlpha: 0,
          stagger: 0.1,
          duration: 0.55,
          ease: 'power3.out',
          delay: 0.25,
          clearProps: 'all',
        })
      },
    }),
  ],
})

new Slider('#demo-hooks-direction', {
  items: 1,
  loop: true,
  speed: 600,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
    fadeEffect({ duration: 600, easing: 'ease-in-out' }),
    hooks({
      onInit({ slides }) {
        gsap.from(slides[0].querySelectorAll('.fade-tag, .fade-title, .fade-sub'), {
          x: 40, autoAlpha: 0, stagger: 0.09, duration: 0.5, ease: 'power3.out', clearProps: 'all',
        })
      },
      beforeChange({ incoming, direction }) {
        const sign = direction === 'forward' ? 1 : -1
        gsap.from((incoming as HTMLElement).querySelectorAll('.fade-tag, .fade-title, .fade-sub'), {
          x: sign * 50,
          autoAlpha: 0,
          stagger: 0.09,
          duration: 0.5,
          ease: 'power3.out',
          delay: 0.2,
          clearProps: 'all',
        })
      },
    }),
  ],
})

let sliderCardsInst: SliderInstance | null = null

new Slider('#demo-hooks-cards', {
  items: 3,
  gutter: 24,
  slideBy: 'page',
  loop: true,
  speed: 400,
  plugins: [
    arrows(),
    hooks({
      onInit({ slider, slides }) {
        sliderCardsInst = slider
        const active = (slides as HTMLElement[]).filter(s =>
          s.classList.contains('sliderkit__item--active') &&
          !s.classList.contains('sliderkit__item--clone')
        )
        active.forEach((card, i) => {
          const d = i * 0.1
          gsap.from(card, { x: 48, autoAlpha: 0, duration: 0.45, ease: 'power3.out', delay: d, clearProps: 'all' })
          gsap.from(card.querySelectorAll('.hc-num, .hc-title, .hc-text, .hc-cta'), {
            y: 18, autoAlpha: 0, stagger: 0.07, duration: 0.38, ease: 'power2.out', delay: d + 0.1, clearProps: 'all',
          })
        })
      },
      beforeChange() {
        if (!sliderCardsInst) return
        // By the time this fires, additionalUpdates() already ran and marked the
        // INCOMING slides as --active. Hide them before the CSS transition starts.
        ;(sliderCardsInst.slides as HTMLElement[]).forEach(s => {
          if (s.classList.contains('sliderkit__item--active'))
            gsap.set(s, { opacity: 0 })
        })
      },
      afterChange({ slide, direction }) {
        if (!sliderCardsInst) return
        const sign = direction === 'forward' ? 1 : -1
        const track = (slide as HTMLElement).parentElement!

        // Reset outgoing slides for next transition
        ;(sliderCardsInst.slides as HTMLElement[]).forEach(s => {
          if (!s.classList.contains('sliderkit__item--active'))
            gsap.set(s, { clearProps: 'opacity' })
        })

        const animateCards = (cards: HTMLElement[]) => {
          cards.forEach((card, i) => {
            const d = i * 0.1
            gsap.fromTo(card,
              { opacity: 0, x: sign * 48 },
              { opacity: 1, x: 0, duration: 0.45, ease: 'power3.out', delay: d, clearProps: 'all' }
            )
            gsap.from(card.querySelectorAll('.hc-num, .hc-title, .hc-text, .hc-cta'), {
              y: sign * 18, autoAlpha: 0, stagger: 0.07, duration: 0.38,
              ease: 'power2.out', delay: d + 0.1, clearProps: 'all',
            })
          })
        }

        const active = [...track.querySelectorAll<HTMLElement>(
          '.sliderkit__item--active:not(.sliderkit__item--clone)'
        )]

        if (active.length > 0) {
          // Normal transition: real active slides found — reveal them
          animateCards(active)
        } else {
          // Loop wrap-around: slider still showing clones; real slides get --active
          // only after the silent jump, which happens synchronously after this callback.
          // rAF fires before the next paint, so we catch the real slides before they're visible.
          requestAnimationFrame(() => {
            const realActive = [...track.querySelectorAll<HTMLElement>(
              '.sliderkit__item--active:not(.sliderkit__item--clone)'
            )]
            animateCards(realActive)
          })
        }
      },
    }),
  ],
})

// ── Focus-center demo ─────────────────────────────────────────────────────

const ORIG_SEL = '.sliderkit__item:not(.sliderkit__item--clone)'

function applyFocus(track: HTMLElement) {
  // Dim all originals
  track.querySelectorAll<HTMLElement>(ORIG_SEL).forEach(s =>
    gsap.to(s, { opacity: 0.5, scale: 0.92, duration: 0.35, ease: 'power2.out', overwrite: true })
  )
  // Dim clones instantly (only briefly visible during loop transitions)
  track.querySelectorAll<HTMLElement>('.sliderkit__item--clone').forEach(s =>
    gsap.set(s, { opacity: 0.5, scale: 0.92 })
  )
  // Center = active[1] counting ALL active items (incl. clones) — correct visual position
  const active = [...track.querySelectorAll<HTMLElement>('.sliderkit__item--active')]
  if (active[1])
    gsap.to(active[1], { opacity: 1, scale: 1, duration: 0.35, ease: 'power2.out', overwrite: true })
}

new Slider('#demo-hooks-focus', {
  items: 3,
  gutter: 16,
  slideBy: 1,
  loop: true,
  speed: 350,
  plugins: [
    arrows(),
    hooks({
      onInit({ slider }) {
        applyFocus(slider.container)
      },
      afterChange({ slide }) {
        // rAF ensures we run after any loop silent-jump, so real slides are already in place
        requestAnimationFrame(() => applyFocus((slide as HTMLElement).parentElement!))
      },
    }),
  ],
})
</script>
