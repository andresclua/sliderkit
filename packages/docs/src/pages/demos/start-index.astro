---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Start Index">

  <DemoViewer
    title="Fixed start index"
    description="Pass startIndex to open the slider at any slide on init. Index is 0-based. The slider is fully functional from there — navigation, loop, everything works normally."
    html={`<div class="c--slider-a" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3 ← starts here</div>
    <div class="c--slider-a__slide">4</div>
    <div class="c--slider-a__slide">5</div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__slide { flex-shrink: 0; width: 100%; height: 260px; }
.c--slider-a__pagination { display: flex; justify-content: center; gap: 6px; padding: 12px 0; }
.c--slider-a__pagination-bullet { width: 10px; height: 10px; border-radius: 50%; background: #d1d5db; border: none; cursor: pointer; transition: background 0.2s, transform 0.2s; }
.c--slider-a__pagination-bullet--active { background: #6C2BD9; transform: scale(1.3); }`}
    js={`import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'

new Slider('#my-slider', {
  startIndex: 2, // 0-based — opens at slide 3
  loop: true,
  plugins: [
    arrows(),
    pagination({ el: '#my-pag', type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a" id="demo-startidx">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3 ← starts here</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-startidx-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="From URL query param"
    description="Read the slide index from the URL (?slide=N) so users can deep-link directly to a specific item. Useful for shared links, notifications, or pagination state in the browser history."
    html={`<div class="c--slider-a" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3</div>
    <div class="c--slider-a__slide">4</div>
    <div class="c--slider-a__slide">5</div>
  </div>
</div>
<!-- Add ?slide=2 to the URL to open at slide 3 -->`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__slide { flex-shrink: 0; width: 100%; height: 260px; }`}
    js={`import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'

// Read ?slide=N from the URL (0-based)
const params = new URLSearchParams(window.location.search)
const startIndex = Math.max(0, parseInt(params.get('slide') ?? '0', 10))

new Slider('#my-slider', {
  startIndex,
  loop: true,
  plugins: [arrows(), pagination({ type: 'dots', clickable: true })],
})`}
  >
    <div class="c--slider-a" id="demo-startidx-url">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-startidx-url-pag" class="c--slider-a__pagination"></div>
    <p class="hint">Add <code>?slide=3</code> to the URL and refresh to open at slide 4.</p>
  </DemoViewer>

  <DemoViewer
    title="Remember last visited slide"
    description="Persist the active slide index in sessionStorage so users come back to where they left off — useful in tabs, modal galleries, or multi-step flows where the user might navigate away and return."
    html={`<div class="c--slider-a" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3</div>
    <div class="c--slider-a__slide">4</div>
    <div class="c--slider-a__slide">5</div>
  </div>
</div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }
.c--slider-a__slide { flex-shrink: 0; width: 100%; height: 260px; }`}
    js={`import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'

const KEY = 'my-slider-index'
const saved = parseInt(sessionStorage.getItem(KEY) ?? '0', 10)

const slider = new Slider('#my-slider', {
  startIndex: saved,
  loop: true,
  plugins: [arrows(), pagination({ type: 'dots', clickable: true })],
})

// Persist on every slide change
slider.on('afterSlideChange', ({ index }) => {
  sessionStorage.setItem(KEY, String(index))
})`}
  >
    <div class="c--slider-a" id="demo-startidx-storage">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-startidx-storage-pag" class="c--slider-a__pagination"></div>
    <p class="hint">Navigate to a different slide, then refresh the page — it will reopen at the same slide.</p>
  </DemoViewer>

</DemoLayout>

<style>
.hint { margin-top: 8px; font-size: 0.82rem; color: var(--text-muted); }
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'

// Demo 1 — fixed index
new Slider('#demo-startidx', {
  startIndex: 2,
  loop: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-startidx-pag', type: 'dots', clickable: true }),
  ],
})

// Demo 2 — from URL
const params = new URLSearchParams(window.location.search)
const urlIndex = Math.max(0, parseInt(params.get('slide') ?? '0', 10))
new Slider('#demo-startidx-url', {
  startIndex: urlIndex,
  loop: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-startidx-url-pag', type: 'dots', clickable: true }),
  ],
})

// Demo 3 — sessionStorage
const KEY = 'demo-startidx-storage'
const saved = parseInt(sessionStorage.getItem(KEY) ?? '0', 10)
const storageSlider = new Slider('#demo-startidx-storage', {
  startIndex: saved,
  loop: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-startidx-storage-pag', type: 'dots', clickable: true }),
  ],
})
storageSlider.on('afterSlideChange', ({ index }: { index: number }) => {
  sessionStorage.setItem(KEY, String(index))
})
</script>
