</DemoLayout>

<style>
.demo-thumb {
  flex: 1;
  height: 56px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #fff;
  opacity: 0.4;
  transition: opacity 0.2s;
}
:global(.sliderkit__thumb--active).demo-thumb {
  opacity: 1;
  outline: 3px solid #6C2BD9;
  outline-offset: 2px;
}
.demo-thumb--fixed {
  flex: 0 0 72px;
}
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { thumbs } from '@andresclua/sliderkit-plugins'

// — demo 1: basic thumbs —
new Slider('#demo-thumbs', {
  items: 1,
  loop: false,
  speed: 300,
  plugins: [thumbs({ container: '#demo-thumbs-strip' })],
})

// — demo 2: many thumbs with scrollable strip —
const slider2 = new Slider('#demo-thumbs-many', {
  items: 1,
  loop: false,
  speed: 300,
  plugins: [
    thumbs({ container: '#demo-thumbs-many-strip' }),
  ],
})

const viewport = document.querySelector<HTMLElement>('.demo-thumb-viewport')!
const strip    = document.getElementById('demo-thumbs-many-strip')!

document.querySelector('.demo-thumb-prev')!.addEventListener('click', () => {
  viewport.scrollBy({ left: -160, behavior: 'smooth' })
})
document.querySelector('.demo-thumb-next')!.addEventListener('click', () => {
  viewport.scrollBy({ left: 160, behavior: 'smooth' })
})

slider2.on('indexChanged', () => {
  const active = strip.children[slider2.activeIndex] as HTMLElement
  if (active) active.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' })
})

// drag-to-scroll on the thumbnail strip
let isDragging = false, dragStartX = 0, dragScrollLeft = 0
viewport.style.cursor = 'grab'
viewport.addEventListener('mousedown', (e) => {
  isDragging    = true
  dragStartX    = e.pageX - viewport.offsetLeft
  dragScrollLeft = viewport.scrollLeft
  viewport.style.cursor = 'grabbing'
})
viewport.addEventListener('mouseleave', () => { isDragging = false; viewport.style.cursor = 'grab' })
viewport.addEventListener('mouseup',    () => { isDragging = false; viewport.style.cursor = 'grab' })
viewport.addEventListener('mousemove',  (e) => {
  if (!isDragging) return
  e.preventDefault()
  const x    = e.pageX - viewport.offsetLeft
  const walk = x - dragStartX
  viewport.scrollLeft = dragScrollLeft - walk
})

// — demo 3: arrows navigate the slider —
const slider3 = new Slider('#demo-thumbs-nav', {
  items: 1,
  loop: false,
  speed: 300,
  plugins: [thumbs({ container: '#demo-thumbs-nav-strip' })],
})

const navViewport = document.querySelector<HTMLElement>('.demo-thumb-nav-viewport')!
const navStrip    = document.getElementById('demo-thumbs-nav-strip')!

document.querySelector('.demo-thumb-nav-prev')!.addEventListener('click', () => slider3.prev())
document.querySelector('.demo-thumb-nav-next')!.addEventListener('click', () => slider3.next())

slider3.on('indexChanged', () => {
  const active = navStrip.children[slider3.activeIndex] as HTMLElement
  if (active) active.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' })
})

let isDragging3 = false, dragStartX3 = 0, dragScrollLeft3 = 0
navViewport.style.cursor = 'grab'
navViewport.addEventListener('mousedown', (e) => {
  isDragging3    = true
  dragStartX3    = e.pageX - navViewport.offsetLeft
  dragScrollLeft3 = navViewport.scrollLeft
  navViewport.style.cursor = 'grabbing'
})
navViewport.addEventListener('mouseleave', () => { isDragging3 = false; navViewport.style.cursor = 'grab' })
navViewport.addEventListener('mouseup',    () => { isDragging3 = false; navViewport.style.cursor = 'grab' })
navViewport.addEventListener('mousemove',  (e) => {
  if (!isDragging3) return
  e.preventDefault()
  navViewport.scrollLeft = dragScrollLeft3 - (e.pageX - navViewport.offsetLeft - dragStartX3)
})
</script>
