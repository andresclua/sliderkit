---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="WebGL — Pixel Dissolve">

  <DemoViewer
    title="Randomised block dissolve"
    description="Each rectangular block is assigned a random dissolve threshold. During the transition, blocks flip from the outgoing slide to the incoming one when progress crosses their threshold — producing a stochastic, pixel-art-style dissolve. blockSize controls the granularity: 8–16 px reads as organic noise, 32 px is clearly blocky, 64 px gives a retro 8-bit look. A longer speed (900–1200 ms) lets the full pattern develop."
    html={`<div class="wgl-slider" id="my-slider">
  <div class="c--slider-a__wrapper">
    <!-- Slides are empty — WebGL renders the images -->
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.wgl-slider { position: relative; height: 400px; overflow: hidden; background: #000; }
.wgl-slider .c--slider-a__wrapper { display: flex; }
.wgl-slide { flex-shrink: 0; width: 100%; height: 100%; }
.wgl-slider canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

const IMAGES = [
  'https://picsum.photos/seed/px1/900/400',
  'https://picsum.photos/seed/px2/900/400',
  'https://picsum.photos/seed/px3/900/400',
  'https://picsum.photos/seed/px4/900/400',
]

const VERT = \`
  attribute vec2 a_pos; attribute vec2 a_uv; varying vec2 vUv;
  void main() { vUv = a_uv; gl_Position = vec4(a_pos, 0.0, 1.0); }
\`
const FRAG = \`
  precision highp float;
  uniform sampler2D uFrom; uniform sampler2D uTo;
  uniform float uProgress;
  uniform vec2  uBlocks;   // (canvasW / blockPx, canvasH / blockPx)
  varying vec2 vUv;

  float rand(vec2 n) {
    return fract(sin(dot(n, vec2(12.9898, 4.1414))) * 43758.5453);
  }
  void main() {
    vec2  blockId  = floor(vUv * uBlocks);
    float thresh   = rand(blockId);
    float amt      = step(thresh, uProgress);
    gl_FragColor   = mix(texture2D(uFrom, vUv), texture2D(uTo, vUv), amt);
  }
\`

// blockSize in CSS pixels
const BLOCK = 32

const container = document.querySelector('#my-slider')
const canvas = document.createElement('canvas')
container.insertBefore(canvas, container.firstChild)
const gl = canvas.getContext('webgl')

let blocksX = 1, blocksY = 1
function resize() {
  const w = container.offsetWidth, h = container.offsetHeight
  canvas.width  = w * Math.min(devicePixelRatio, 2)
  canvas.height = h * Math.min(devicePixelRatio, 2)
  canvas.style.width = w + 'px'; canvas.style.height = h + 'px'
  gl.viewport(0, 0, canvas.width, canvas.height)
  blocksX = canvas.width  / BLOCK
  blocksY = canvas.height / BLOCK
}
resize(); window.addEventListener('resize', resize)

// ... compile prog, create quad buffers, loadTex same as displacement demo ...

Promise.all(IMAGES.map(loadTex)).then(textures => {
  draw(textures[0], textures[0], 0)

  const slider = new Slider('#my-slider', {
    loop: true, speed: 1,
    plugins: [arrows(), pagination({ el: '#my-pag', type: 'dots', clickable: true })],
  })

  slider.on('afterSlideChange', ({ index, previousIndex }) => {
    animateTransition(textures[previousIndex], textures[index], 900)
  })
})`}
  >
    <div class="wgl-slider" id="demo-pixeldissolve">
      <div class="c--slider-a__wrapper">
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
      </div>
    </div>
    <div id="demo-pxd-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="Chunky 8-bit dissolve"
    description="The same shader with blockSize set to 56 px, producing large retro blocks. Combining a longer speed (1100 ms) with big blocks lets each one pop visibly — the effect reads as deliberate, almost game-over-screen pixelation rather than noise."
    html={`<div class="wgl-slider" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.wgl-slider { position: relative; height: 400px; overflow: hidden; background: #000; }
.wgl-slider .c--slider-a__wrapper { display: flex; }
.wgl-slide { flex-shrink: 0; width: 100%; height: 100%; }
.wgl-slider canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }`}
    js={`// Same setup — only blockSize changes
const BLOCK = 56   // large blocks → retro 8-bit look

new Slider('#my-slider', {
  loop: true, speed: 1,
  plugins: [arrows(), pagination({ el: '#my-pag', type: 'dots', clickable: true })],
})`}
  >
    <div class="wgl-slider" id="demo-pixeldissolve-chunky">
      <div class="c--slider-a__wrapper">
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
      </div>
    </div>
    <div id="demo-pxd-chunky-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

</DemoLayout>

<style>
.wgl-slider { position: relative; aspect-ratio: 2/1; overflow: hidden; background: #111; }
.wgl-slider .c--slider-a__wrapper { display: flex; }
.wgl-slide  { flex-shrink: 0; width: 100%; height: 100%; }
.wgl-slider canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
.wgl-slider :global(.c--slider-a__arrow) { z-index: 2; }
.wgl-slider :global(.c--slider-a__pagination) { position: relative; z-index: 2; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

// ─── Shared shaders ───────────────────────────────────────────────────────────
const VERT = `
  attribute vec2 a_pos;
  attribute vec2 a_uv;
  varying vec2 vUv;
  void main() { vUv = a_uv; gl_Position = vec4(a_pos, 0.0, 1.0); }
`
const FRAG_PXD = `
  precision highp float;
  uniform sampler2D uFrom;
  uniform sampler2D uTo;
  uniform float uProgress;
  uniform vec2  uBlocks;
  uniform vec2  uCanvas;
  uniform float uImg;
  varying vec2 vUv;

  vec2 cover(vec2 uv) {
    float ca = uCanvas.x / uCanvas.y;
    vec2 s = ca > uImg ? vec2(ca / uImg, 1.0) : vec2(1.0, uImg / ca);
    return (uv - 0.5) / s + 0.5;
  }

  float rand(vec2 n) {
    return fract(sin(dot(n, vec2(12.9898, 4.1414))) * 43758.5453);
  }
  void main() {
    vec2  blockId = floor(vUv * uBlocks);
    float thresh  = rand(blockId);
    float amt     = step(thresh, uProgress);
    vec2  uv      = cover(vUv);
    gl_FragColor  = mix(texture2D(uFrom, uv), texture2D(uTo, uv), amt);
  }
`

function initPXD(container: HTMLElement, blockPx: number) {
  const canvas = document.createElement('canvas')
  container.insertBefore(canvas, container.firstChild)
  const gl = canvas.getContext('webgl')!

  let blocksX = 1, blocksY = 1
  let _redraw: (() => void) | null = null
  function resize() {
    const w = container.offsetWidth, h = container.offsetHeight
    canvas.width  = w * Math.min(devicePixelRatio, 2)
    canvas.height = h * Math.min(devicePixelRatio, 2)
    canvas.style.width = w + 'px'
    canvas.style.height = h + 'px'
    gl.viewport(0, 0, canvas.width, canvas.height)
    blocksX = canvas.width  / blockPx
    blocksY = canvas.height / blockPx
    _redraw?.()
  }
  resize()
  window.addEventListener('resize', resize)

  const compile = (type: number, src: string) => {
    const s = gl.createShader(type)!; gl.shaderSource(s, src); gl.compileShader(s); return s
  }
  const prog = gl.createProgram()!
  gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT))
  gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG_PXD))
  gl.linkProgram(prog)

  const posData = new Float32Array([-1,-1, 1,-1, -1,1, 1,1])
  const uvData  = new Float32Array([0,1,  1,1,  0,0,  1,0])
  const posBuf  = gl.createBuffer()!; gl.bindBuffer(gl.ARRAY_BUFFER, posBuf); gl.bufferData(gl.ARRAY_BUFFER, posData, gl.STATIC_DRAW)
  const uvBuf   = gl.createBuffer()!; gl.bindBuffer(gl.ARRAY_BUFFER, uvBuf);  gl.bufferData(gl.ARRAY_BUFFER, uvData,  gl.STATIC_DRAW)

  const aPos    = gl.getAttribLocation(prog, 'a_pos')
  const aUv     = gl.getAttribLocation(prog, 'a_uv')
  const uFrom   = gl.getUniformLocation(prog, 'uFrom')!
  const uTo     = gl.getUniformLocation(prog, 'uTo')!
  const uProg   = gl.getUniformLocation(prog, 'uProgress')!
  const uBlocks = gl.getUniformLocation(prog, 'uBlocks')!
  const uCanvas = gl.getUniformLocation(prog, 'uCanvas')!
  const uImgLoc = gl.getUniformLocation(prog, 'uImg')!

  const texAspects = new Map<WebGLTexture, number>()

  function draw(from: WebGLTexture, to: WebGLTexture, progress: number) {
    _redraw = () => draw(from, to, progress)
    gl.useProgram(prog)
    gl.bindBuffer(gl.ARRAY_BUFFER, posBuf); gl.enableVertexAttribArray(aPos); gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0)
    gl.bindBuffer(gl.ARRAY_BUFFER, uvBuf);  gl.enableVertexAttribArray(aUv);  gl.vertexAttribPointer(aUv,  2, gl.FLOAT, false, 0, 0)
    gl.activeTexture(gl.TEXTURE0); gl.bindTexture(gl.TEXTURE_2D, from); gl.uniform1i(uFrom, 0)
    gl.activeTexture(gl.TEXTURE1); gl.bindTexture(gl.TEXTURE_2D, to);   gl.uniform1i(uTo, 1)
    gl.uniform1f(uProg, progress)
    gl.uniform2f(uBlocks, blocksX, blocksY)
    gl.uniform2f(uCanvas, canvas.width, canvas.height)
    gl.uniform1f(uImgLoc, texAspects.get(from) ?? 1.0)
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4)
  }

  function loadTex(src: string): Promise<WebGLTexture> {
    return new Promise(resolve => {
      const img = new Image(); img.crossOrigin = 'anonymous'
      img.onload = () => {
        const t = gl.createTexture()!
        gl.bindTexture(gl.TEXTURE_2D, t)
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, img)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE)
        texAspects.set(t, img.naturalWidth / img.naturalHeight)
        resolve(t)
      }
      img.src = src
    })
  }

  return { draw, loadTex }
}

function runSlider(containerId: string, pagId: string, images: string[], blockPx: number, dur: number) {
  const el = document.getElementById(containerId)!
  const { draw, loadTex } = initPXD(el, blockPx)

  Promise.all(images.map(loadTex)).then(textures => {
    draw(textures[0], textures[0], 0)

    const slider = new Slider('#' + containerId, {
      loop: true,
      speed: 1,
      plugins: [
        arrows(),
        pagination({ el: '#' + pagId, type: 'dots', clickable: true }),
      ],
    })

    let rafId: number | null = null
    slider.on('afterSlideChange', ({ index, previousIndex }: { index: number; previousIndex: number }) => {
      if (rafId !== null) cancelAnimationFrame(rafId)
      const from = textures[previousIndex], to = textures[index]
      const start = performance.now()
      const tick = (now: number) => {
        const t = Math.min((now - start) / dur, 1)
        draw(from, to, t)   // linear — the random thresholds create the organic feel
        if (t < 1) rafId = requestAnimationFrame(tick)
        else { draw(to, to, 0); rafId = null }
      }
      rafId = requestAnimationFrame(tick)
    })
  })
}

// ─── Fine grain (32 px blocks, 900 ms) ───────────────────────────────────────
runSlider('demo-pixeldissolve', 'demo-pxd-pag', [
  'https://picsum.photos/seed/px1/900/400',
  'https://picsum.photos/seed/px2/900/400',
  'https://picsum.photos/seed/px3/900/400',
  'https://picsum.photos/seed/px4/900/400',
], 32, 900)

// ─── Chunky 8-bit (56 px blocks, 1100 ms) ────────────────────────────────────
runSlider('demo-pixeldissolve-chunky', 'demo-pxd-chunky-pag', [
  'https://picsum.photos/seed/chunky1/900/400',
  'https://picsum.photos/seed/chunky2/900/400',
  'https://picsum.photos/seed/chunky3/900/400',
], 56, 1100)
</script>
