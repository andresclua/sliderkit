---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Freeze / Disable">
  <DemoViewer
    title="Freeze & Disable"
    description="freezable:true auto-disables the slider when all slides fit on screen. Resize the window to see it activate/deactivate."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`.demo-slide { height: 260px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  loop: false,
  freezable: true,
  responsive: {
    640: { items: 3 },
    900: { items: 5 }, // all 5 fit → slider freezes
  },
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})`}
  >
    <div id="demo-freeze">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#demo-freeze', {
  items: 1,
  loop: false,
  freezable: true,
  responsive: {
    640: { items: 3 },
    900: { items: 5 },
  },
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})
</script>
