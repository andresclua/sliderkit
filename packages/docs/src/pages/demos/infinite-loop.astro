---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Infinite Loop">
  <DemoViewer
    title="Infinite loop — 1 slide per page"
    description="Set loop: true to wrap seamlessly from the last slide back to the first. Clones of the boundary slides are inserted in the DOM so the animation always looks continuous."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>`}
    css={`.c--slider-a__item { height: 260px; }

.c--slider-a__arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10; width: 40px; height: 40px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.9); cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.c--slider-a__arrow--prev { left: 12px; }
.c--slider-a__arrow--next { right: 12px; }

.c--slider-a__pagination {
  display: flex; align-items: center; justify-content: center;
  gap: 6px; padding: 12px 0;
}
.c--slider-a__pagination-bullet {
  width: 10px; height: 10px; border-radius: 50%;
  background: #d1d5db; border: none; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.c--slider-a__pagination-bullet--active { background: #6C2BD9; transform: scale(1.3); }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  loop: true,
  speed: 350,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})`}
  >
    <div id="demo-loop-1">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
  </DemoViewer>

  <DemoViewer
    title="Infinite loop — 2 slides per page"
    description="Loop works with any items count. The slider clones boundary slides so transitions always animate smoothly."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
  <div class="demo-slide s-pink">6</div>
</div>`}
    css={`.c--slider-a__item { height: 220px; }

.c--slider-a__arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10; width: 40px; height: 40px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.9); cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.c--slider-a__arrow--prev { left: 8px; }
.c--slider-a__arrow--next { right: 8px; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 2,
  gutter: 16,
  loop: true,
  speed: 350,
  plugins: [arrows()],
})`}
  >
    <div id="demo-loop-2">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
      <div class="demo-slide s-pink">6</div>
    </div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#demo-loop-1', {
  items: 1,
  loop: true,
  speed: 350,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})

new Slider('#demo-loop-2', {
  items: 2,
  gutter: 16,
  loop: true,
  speed: 350,
  plugins: [arrows()],
})
</script>
