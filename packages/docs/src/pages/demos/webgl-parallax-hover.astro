---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="WebGL — Parallax Hover">

  <DemoViewer
    title="Mouse-driven depth parallax"
    description="The slide image is rendered at 110% scale so the edges never show during movement. As the mouse moves over the slider, the UV coordinates are shifted proportionally — foreground appears to move more than the background, simulating depth. intensity controls how many UV units shift per unit of mouse travel (0.04 is subtle, 0.08 is dramatic). Transitions between slides are a simple cross-fade while preserving the live parallax offset."
    html={`<div class="wgl-slider" id="my-slider">
  <div class="c--slider-a__wrapper">
    <!-- Slides are empty — WebGL renders the images -->
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
    <div class="wgl-slide" data-slide></div>
  </div>
</div>`}
    css={`.wgl-slider { position: relative; height: 400px; overflow: hidden; background: #000; cursor: none; }
.wgl-slider .c--slider-a__wrapper { display: flex; }
.wgl-slide { flex-shrink: 0; width: 100%; height: 100%; }
.wgl-slider canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

const VERT = \`
  attribute vec2 a_pos; attribute vec2 a_uv; varying vec2 vUv;
  void main() { vUv = a_uv; gl_Position = vec4(a_pos, 0.0, 1.0); }
\`
const FRAG = \`
  precision highp float;
  uniform sampler2D uFrom; uniform sampler2D uTo;
  uniform float uProgress; uniform vec2 uOffset;
  varying vec2 vUv;
  void main() {
    // Zoom in by ~10% and shift — edges never clip
    vec2 uv = (vUv - 0.5) / 1.1 + 0.5 + uOffset;
    gl_FragColor = mix(texture2D(uFrom, uv), texture2D(uTo, uv), uProgress);
  }
\`

const container = document.querySelector('#my-slider')
// ... WebGL setup, load textures ...

// Track mouse, lerp offset
let targetX = 0, targetY = 0
let currX   = 0, currY   = 0

container.addEventListener('mousemove', e => {
  const r = container.getBoundingClientRect()
  targetX = ((e.clientX - r.left) / r.width  - 0.5) * -0.06
  targetY = ((e.clientY - r.top)  / r.height - 0.5) * -0.06
})

// RAF loop: lerp currX/Y toward targetX/Y, redraw every frame
const loop = () => {
  currX += (targetX - currX) * 0.08
  currY += (targetY - currY) * 0.08
  draw(currentTex, currentTex, 0, currX, currY)
  requestAnimationFrame(loop)
}`}
  >
    <div class="wgl-slider" id="demo-parallax">
      <div class="c--slider-a__wrapper">
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
        <div class="wgl-slide" data-slide></div>
      </div>
    </div>
  </DemoViewer>

  <DemoViewer
    title="Standalone tilt card"
    description="A single hero image with mouse-driven tilt — no slider required. The image floats within its container, shifting based on cursor position relative to centre. intensity 0.05 gives a gentle card-tilt feel; go up to 0.12 for a dramatic 3D pop. The lerp factor (0.06) controls how snappily the image tracks the cursor."
    html={`<div class="tilt-card" id="my-tilt">
  <!-- Canvas injected by JS -->
</div>`}
    css={`.tilt-card {
  width: 100%;
  height: 340px;
  position: relative;
  overflow: hidden;
  background: #000;
  cursor: crosshair;
}
.tilt-card canvas { position: absolute; inset: 0; display: block; }`}
    js={`const el = document.getElementById('my-tilt')
// ... WebGL setup, single texture loaded ...

let tx = 0, ty = 0, cx = 0, cy = 0
el.addEventListener('mousemove', e => {
  const r = el.getBoundingClientRect()
  tx = ((e.clientX - r.left) / r.width  - 0.5) * -0.08
  ty = ((e.clientY - r.top)  / r.height - 0.5) * -0.08
})
el.addEventListener('mouseleave', () => { tx = 0; ty = 0 })

// Continuous render loop with lerp
;(function loop() {
  cx += (tx - cx) * 0.06
  cy += (ty - cy) * 0.06
  draw(tex, tex, 0, cx, cy)
  requestAnimationFrame(loop)
})()`}
  >
    <div class="tilt-card" id="demo-tilt"></div>
  </DemoViewer>

</DemoLayout>

<style>
.wgl-slider { position: relative; aspect-ratio: 2/1; overflow: hidden; background: #111; }
.wgl-slider .c--slider-a__wrapper { display: flex; }
.wgl-slide  { flex-shrink: 0; width: 100%; height: 100%; }
.wgl-slider canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
.wgl-slider :global(.c--slider-a__arrow) { z-index: 2; }

.tilt-card { width: 100%; aspect-ratio: 2.5/1; position: relative; overflow: hidden; background: #111; cursor: crosshair; }
.tilt-card canvas { position: absolute; inset: 0; display: block; width: 100%; height: 100%; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

// ─── Shared shaders ───────────────────────────────────────────────────────────
const VERT = `
  attribute vec2 a_pos;
  attribute vec2 a_uv;
  varying vec2 vUv;
  void main() { vUv = a_uv; gl_Position = vec4(a_pos, 0.0, 1.0); }
`
const FRAG_PAR = `
  precision highp float;
  uniform sampler2D uFrom;
  uniform sampler2D uTo;
  uniform float uProgress;
  uniform vec2  uOffset;
  uniform vec2  uCanvas;
  uniform float uImg;
  varying vec2 vUv;

  vec2 cover(vec2 uv) {
    float ca = uCanvas.x / uCanvas.y;
    vec2 s = ca > uImg ? vec2(ca / uImg, 1.0) : vec2(1.0, uImg / ca);
    return (uv - 0.5) / s + 0.5;
  }

  void main() {
    // Apply cover first, then zoom in 10% to give parallax room to move
    vec2 uv = cover(vUv);
    uv = (uv - 0.5) / 1.1 + 0.5 + uOffset;
    uv = clamp(uv, 0.0, 1.0);
    gl_FragColor = mix(texture2D(uFrom, uv), texture2D(uTo, uv), uProgress);
  }
`

function initPar(container: HTMLElement) {
  const canvas = document.createElement('canvas')
  container.insertBefore(canvas, container.firstChild)
  const gl = canvas.getContext('webgl')!

  function resize() {
    const w = container.offsetWidth, h = container.offsetHeight
    canvas.width  = w * Math.min(devicePixelRatio, 2)
    canvas.height = h * Math.min(devicePixelRatio, 2)
    canvas.style.width = w + 'px'
    canvas.style.height = h + 'px'
    gl.viewport(0, 0, canvas.width, canvas.height)
  }
  resize()
  window.addEventListener('resize', resize)

  const compile = (type: number, src: string) => {
    const s = gl.createShader(type)!; gl.shaderSource(s, src); gl.compileShader(s); return s
  }
  const prog = gl.createProgram()!
  gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT))
  gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG_PAR))
  gl.linkProgram(prog)

  const posData = new Float32Array([-1,-1, 1,-1, -1,1, 1,1])
  const uvData  = new Float32Array([0,1,  1,1,  0,0,  1,0])
  const posBuf  = gl.createBuffer()!; gl.bindBuffer(gl.ARRAY_BUFFER, posBuf); gl.bufferData(gl.ARRAY_BUFFER, posData, gl.STATIC_DRAW)
  const uvBuf   = gl.createBuffer()!; gl.bindBuffer(gl.ARRAY_BUFFER, uvBuf);  gl.bufferData(gl.ARRAY_BUFFER, uvData,  gl.STATIC_DRAW)

  const aPos    = gl.getAttribLocation(prog, 'a_pos')
  const aUv     = gl.getAttribLocation(prog, 'a_uv')
  const uFrom   = gl.getUniformLocation(prog, 'uFrom')!
  const uTo     = gl.getUniformLocation(prog, 'uTo')!
  const uProg   = gl.getUniformLocation(prog, 'uProgress')!
  const uOffset = gl.getUniformLocation(prog, 'uOffset')!
  const uCanvas = gl.getUniformLocation(prog, 'uCanvas')!
  const uImgLoc = gl.getUniformLocation(prog, 'uImg')!

  const texAspects = new Map<WebGLTexture, number>()

  function draw(from: WebGLTexture, to: WebGLTexture, progress: number, ox: number, oy: number) {
    gl.useProgram(prog)
    gl.bindBuffer(gl.ARRAY_BUFFER, posBuf); gl.enableVertexAttribArray(aPos); gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0)
    gl.bindBuffer(gl.ARRAY_BUFFER, uvBuf);  gl.enableVertexAttribArray(aUv);  gl.vertexAttribPointer(aUv,  2, gl.FLOAT, false, 0, 0)
    gl.activeTexture(gl.TEXTURE0); gl.bindTexture(gl.TEXTURE_2D, from); gl.uniform1i(uFrom, 0)
    gl.activeTexture(gl.TEXTURE1); gl.bindTexture(gl.TEXTURE_2D, to);   gl.uniform1i(uTo, 1)
    gl.uniform1f(uProg, progress)
    gl.uniform2f(uOffset, ox, oy)
    gl.uniform2f(uCanvas, canvas.width, canvas.height)
    gl.uniform1f(uImgLoc, texAspects.get(from) ?? 1.0)
    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4)
  }

  function loadTex(src: string): Promise<WebGLTexture> {
    return new Promise(resolve => {
      const img = new Image(); img.crossOrigin = 'anonymous'
      img.onload = () => {
        const t = gl.createTexture()!
        gl.bindTexture(gl.TEXTURE_2D, t)
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, img)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE)
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE)
        texAspects.set(t, img.naturalWidth / img.naturalHeight)
        resolve(t)
      }
      img.src = src
    })
  }

  return { draw, loadTex }
}

// ─── Slider demo ─────────────────────────────────────────────────────────────
const SLIDER_IMGS = [
  'https://picsum.photos/seed/par1/900/400',
  'https://picsum.photos/seed/par2/900/400',
  'https://picsum.photos/seed/par3/900/400',
]

const sliderEl = document.getElementById('demo-parallax')!
const { draw: drawSlider, loadTex: loadSliderTex } = initPar(sliderEl)

Promise.all(SLIDER_IMGS.map(loadSliderTex)).then(textures => {
  let currentIdx = 0
  let transFrom: WebGLTexture | null = null
  let transTo:   WebGLTexture | null = null
  let transProgress = 0
  let transRaf: number | null = null

  // Mouse parallax state
  let targetX = 0, targetY = 0, currX = 0, currY = 0

  sliderEl.addEventListener('mousemove', (e: MouseEvent) => {
    const r = sliderEl.getBoundingClientRect()
    targetX = ((e.clientX - r.left) / r.width  - 0.5) * -0.06
    targetY = ((e.clientY - r.top)  / r.height - 0.5) * -0.06
  })
  sliderEl.addEventListener('mouseleave', () => { targetX = 0; targetY = 0 })

  // Continuous render loop
  const renderLoop = () => {
    currX += (targetX - currX) * 0.08
    currY += (targetY - currY) * 0.08
    const from = transFrom ?? textures[currentIdx]
    const to   = transTo   ?? textures[currentIdx]
    drawSlider(from, to, transProgress, currX, currY)
    requestAnimationFrame(renderLoop)
  }
  requestAnimationFrame(renderLoop)

  const slider = new Slider('#demo-parallax', {
    loop: true,
    speed: 1,
    plugins: [arrows()],
  })

  slider.on('afterSlideChange', ({ index, previousIndex }: { index: number; previousIndex: number }) => {
    if (transRaf !== null) cancelAnimationFrame(transRaf)
    currentIdx = index
    transFrom = textures[previousIndex]
    transTo   = textures[index]
    transProgress = 0
    const dur = 600, start = performance.now()
    const tick = (now: number) => {
      transProgress = Math.min((now - start) / dur, 1)
      if (transProgress < 1) transRaf = requestAnimationFrame(tick)
      else { transFrom = null; transTo = null; transProgress = 0; transRaf = null }
    }
    transRaf = requestAnimationFrame(tick)
  })
})

// ─── Tilt card demo ───────────────────────────────────────────────────────────
const tiltEl = document.getElementById('demo-tilt')!
const { draw: drawTilt, loadTex: loadTiltTex } = initPar(tiltEl)

loadTiltTex('https://picsum.photos/seed/tilt1/900/340').then(tex => {
  let tx = 0, ty = 0, cx = 0, cy = 0

  tiltEl.addEventListener('mousemove', (e: MouseEvent) => {
    const r = tiltEl.getBoundingClientRect()
    tx = ((e.clientX - r.left) / r.width  - 0.5) * -0.08
    ty = ((e.clientY - r.top)  / r.height - 0.5) * -0.08
  })
  tiltEl.addEventListener('mouseleave', () => { tx = 0; ty = 0 })

  const loop = () => {
    cx += (tx - cx) * 0.06
    cy += (ty - cy) * 0.06
    drawTilt(tex, tex, 0, cx, cy)
    requestAnimationFrame(loop)
  }
  requestAnimationFrame(loop)
})
</script>
