<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { gsap } from 'gsap'

// ── Demo 1: gutter + fraction pagination ─────────────────────────────────────
new Slider('#demo-gutter', {
  slidesPerPage: 3,
  gutter: 16,
  edgePadding: 40,
  loop: false,
  rewind: true,
  plugins: [
    arrows(),
    pagination({ el: '#demo-gutter-pag', type: 'fraction' }),
  ],
})

// ── Demo 2: center focus with GSAP scale ─────────────────────────────────────
const centerSlider = new Slider('#demo-center', {
  slidesPerPage: 1,
  edgePadding: 64,
  loop: true,
  speed: 480,
  plugins: [arrows()],
})

const centerEl = document.querySelector('#demo-center')!

function syncCenterScale() {
  const all    = centerEl.querySelectorAll('.c--slider-a__slide')
  const active = centerEl.querySelector('.c--slider-a__slide--active')
  gsap.to(all,    { scale: 0.85, duration: 0.4, ease: 'power2.out' })
  if (active)
    gsap.to(active, { scale: 1,    duration: 0.4, ease: 'power2.out', overwrite: 'auto' })
}

gsap.set(centerEl.querySelectorAll('.c--slider-a__slide'), { scale: 0.85 })
gsap.set(centerEl.querySelector('.c--slider-a__slide--active'), { scale: 1 })

centerSlider.on('afterSlideChange', syncCenterScale)

// ── Demo 3: depth-of-field filmstrip (infinite loop) ─────────────────────────
// Blur indexed by DISTANCE from center of the visible 5-slide window:
//   slot position:  [0]   [1]   [2]    [3]   [4]
//   dist from [2]:   2     1     0      1     2
//   blur:          12px   5px   0px    5px  12px
const FILM_BLUR = [0, 2, 4] // index = distance from center

const filmSlider = new Slider('#demo-film', {
  slidesPerPage: 5,
  gutter: 24,
  loop: true,
  speed: 500,
  plugins: [arrows()],
})

const filmSlides = filmSlider.slides

function applyFilmBlur(activeIdx: number, snap = false) {
  const n = filmSlides.length
  filmSlides.forEach((slide, i) => {
    // wrap-safe distance from center of visible window (activeIdx + 2)
    const raw  = ((i - activeIdx - 2) % n + n) % n
    const dist = Math.min(raw, n - raw)
    const px   = FILM_BLUR[Math.min(dist, FILM_BLUR.length - 1)]
    if (snap) gsap.set(slide, { filter: `blur(${px}px)` })
    else      gsap.to(slide,  { filter: `blur(${px}px)`, duration: 0.45, ease: 'power2.out' })
  })
}

// Wait one frame so the slider has laid out slide widths before setting blur
requestAnimationFrame(() => applyFilmBlur(filmSlider.activeIndex, true))

filmSlider.on('afterSlideChange', ({ index }: { index: number }) => applyFilmBlur(index))

// Snap blur to clone-zone positions before the loop boundary animation plays
filmSlider.on('beforeLoopBoundary', ({ targetIndex }: { targetIndex: number }) => applyFilmBlur(targetIndex, true))

// ── Demo 4: fan rotation (infinite loop) ─────────────────────────────────────
const fanSlider = new Slider('#demo-fan', {
  slidesPerPage: 5,
  gutter: 24,
  loop: true,
  speed: 500,
  plugins: [arrows()],
})

const fanContainer  = document.querySelector('#demo-fan')!
const fanWrapper    = fanContainer.querySelector<HTMLElement>('.c--slider-a__wrapper')!

function applyFanRotation(snap = false) {
  // Use offsetLeft (layout coords, unaffected by rotation transforms) +
  // the wrapper's translateX so we get position relative to the container.
  // This works at init AND for clones without any timing issues.
  const tx      = new DOMMatrix(fanWrapper.style.transform).m41   // wrapper translateX
  const cw      = (fanContainer as HTMLElement).offsetWidth
  const cx      = cw / 2                                          // container center
  const slideW  = (fanSlider.slides[0] as HTMLElement).offsetWidth || 1

  fanContainer.querySelectorAll<HTMLElement>('.c--slider-a__slide').forEach(slide => {
    const slideCenter = slide.offsetLeft + tx + slide.offsetWidth / 2
    const slot = Math.round((slideCenter - cx) / (slideW + 24))
    const deg  = Math.max(-12, Math.min(12, slot * 6))
    if (snap) gsap.set(slide, { rotation: deg })
    else      gsap.to(slide,  { rotation: deg, duration: 0.45, ease: 'power2.out' })
  })
}

// Direct call — slider sets wrapper.style.transform synchronously in its constructor
applyFanRotation(true)
fanSlider.on('afterSlideChange', () => applyFanRotation())

// Before the loop boundary animation plays, wrapper.style.transform is already set
// to the clone-zone target. Snap all slide rotations now so clones look correct
// as they animate into view (otherwise clones would show stale rotations from their
// last off-screen position and visually "jump" into place after the transition).
fanSlider.on('beforeLoopBoundary', () => applyFanRotation(true))
</script>
