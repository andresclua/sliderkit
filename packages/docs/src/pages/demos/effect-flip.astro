---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Effect — Flip">

  <DemoViewer
    title="Card flip (Y axis)"
    description="Each slide flips like a playing card on the Y axis. The outgoing slide rotates 90° away while the incoming slides in from −90°. Requires the effect layout (stacked absolute slides) and CSS perspective on the container. backface-visibility: hidden prevents the back of the card from showing through."
    html={`<div class="c--slider-a c--slider-a--effect c--slider-a--flip" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__item">1</div>
    <div class="c--slider-a__item">2</div>
    <div class="c--slider-a__item">3</div>
    <div class="c--slider-a__item">4</div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }

/* Effect layout: stacked absolute slides */
.c--slider-a--effect { height: 260px; }
.c--slider-a--effect .c--slider-a__wrapper { height: 100%; }
.c--slider-a--effect .c--slider-a__item {
  position: absolute; inset: 0; width: 100%; height: 100%;
}

/* Flip: perspective + no back-face bleed */
.c--slider-a--flip { perspective: 1200px; }
.c--slider-a--flip .c--slider-a__item {
  transition: transform 0.6s ease;
  backface-visibility: hidden;
}`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { flipEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [
    flipEffect(),
    arrows(),
    pagination({ el: '#my-pag', type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect c--slider-a--flip" id="demo-flip">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__item demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__item demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__item demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__item demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__item demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-flip-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="Flip with autoplay"
    description="Flip combined with autoplay creates a rotating info-card display — great for testimonial carousels, feature highlights, or rotating announcements. Keep speed (800ms) and delay (3000ms) generous enough for users to read the content before it flips."
    html={`<div class="c--slider-a c--slider-a--effect c--slider-a--flip" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__item">Card A</div>
    <div class="c--slider-a__item">Card B</div>
    <div class="c--slider-a__item">Card C</div>
  </div>
</div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }

.c--slider-a--effect { height: 260px; }
.c--slider-a--effect .c--slider-a__wrapper { height: 100%; }
.c--slider-a--effect .c--slider-a__item {
  position: absolute; inset: 0; width: 100%; height: 100%;
}

.c--slider-a--flip { perspective: 1200px; }
.c--slider-a--flip .c--slider-a__item {
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  backface-visibility: hidden;
}`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { autoplay } from '@andresclua/sliderkit-plugins'
import { flipEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  loop: true,
  speed: 800,
  plugins: [
    flipEffect(),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect c--slider-a--flip" id="demo-flip-auto">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__item demo-slide s-purple" data-slide>Card A</div>
        <div class="c--slider-a__item demo-slide s-blue"   data-slide>Card B</div>
        <div class="c--slider-a__item demo-slide s-green"  data-slide>Card C</div>
        <div class="c--slider-a__item demo-slide s-amber"  data-slide>Card D</div>
      </div>
    </div>
  </DemoViewer>

</DemoLayout>

<style>
.c--slider-a--flip { perspective: 1200px; }
.c--slider-a--flip .c--slider-a__item {
  transition: transform 0.6s ease;
  backface-visibility: hidden;
}
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay } from '@andresclua/sliderkit-plugins'
import { flipEffect } from '@andresclua/sliderkit-effects'

new Slider('#demo-flip', {
  slidesPerPage: 1,
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [
    flipEffect(),
    arrows(),
    pagination({ el: '#demo-flip-pag', type: 'dots', clickable: true }),
  ],
})

new Slider('#demo-flip-auto', {
  slidesPerPage: 1,
  loop: true,
  speed: 800,
  plugins: [
    flipEffect(),
    autoplay({ delay: 3000, pauseOnHover: true }),
  ],
})
</script>
