---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Effect — Fade">

  <DemoViewer
    title="Cross-fade"
    description="Both slides are visible simultaneously during the transition — the outgoing fades out while the incoming fades in. crossFade: true. The cleanest option for hero banners or image galleries."
    html={`<div class="c--slider-a c--slider-a--effect" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide">1</div>
    <div class="c--slider-a__slide">2</div>
    <div class="c--slider-a__slide">3</div>
  </div>
</div>
<div id="my-pag" class="c--slider-a__pagination"></div>`}
    css={`.c--slider-a { position: relative; width: 100%; overflow: hidden; }
.c--slider-a__wrapper { display: flex; will-change: transform; }

/* Stacked layout required for all absolute-position effects */
.c--slider-a--effect { height: 260px; }
.c--slider-a--effect .c--slider-a__wrapper { height: 100%; }
.c--slider-a--effect .c--slider-a__slide {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  opacity: 0; transition: opacity 600ms ease;
}
.c--slider-a--effect .c--slider-a__slide.is-active { opacity: 1; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'
import { fadeEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [
    fadeEffect({ crossFade: true }),
    arrows(),
    pagination({ el: '#my-pag', type: 'dots', clickable: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-fade">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-fade-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>

  <DemoViewer
    title="Fade + autoplay"
    description="Fade combined with autoplay creates a classic full-screen slideshow. Pair a long delay (4–6 s) with a slow fade speed (800–1200 ms) for a smooth, unobtrusive background effect."
    html={`<div class="c--slider-a c--slider-a--effect" id="my-slider">
  <div class="c--slider-a__wrapper">
    <div class="c--slider-a__slide img-slide">
      <img src="/hero1.jpg" alt="Hero 1" />
    </div>
    <div class="c--slider-a__slide img-slide">
      <img src="/hero2.jpg" alt="Hero 2" />
    </div>
  </div>
</div>`}
    css={`.c--slider-a--effect { height: 300px; }
.c--slider-a--effect .c--slider-a__wrapper { height: 100%; }
.img-slide { position: absolute; inset: 0; overflow: hidden; }
.img-slide img { width: 100%; height: 100%; object-fit: cover; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { autoplay } from '@andresclua/sliderkit-plugins'
import { fadeEffect } from '@andresclua/sliderkit-effects'

new Slider('#my-slider', {
  loop: true,
  speed: 1200,
  plugins: [
    fadeEffect({ crossFade: true }),
    autoplay({ delay: 4000, pauseOnHover: true }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-fade-auto">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide fade-img-slide" data-slide>
          <img src="https://picsum.photos/seed/fad1/900/300" alt="Hero 1" />
        </div>
        <div class="c--slider-a__slide fade-img-slide" data-slide>
          <img src="https://picsum.photos/seed/fad2/900/300" alt="Hero 2" />
        </div>
        <div class="c--slider-a__slide fade-img-slide" data-slide>
          <img src="https://picsum.photos/seed/fad3/900/300" alt="Hero 3" />
        </div>
        <div class="c--slider-a__slide fade-img-slide" data-slide>
          <img src="https://picsum.photos/seed/fad4/900/300" alt="Hero 4" />
        </div>
      </div>
    </div>
  </DemoViewer>

</DemoLayout>

<style>
.fade-img-slide { position: absolute; inset: 0; overflow: hidden; }
.fade-img-slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination, autoplay } from '@andresclua/sliderkit-plugins'
import { fadeEffect } from '@andresclua/sliderkit-effects'

new Slider('#demo-fade', {
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [
    fadeEffect({ crossFade: true }),
    arrows(),
    pagination({ el: '#demo-fade-pag', type: 'dots', clickable: true }),
  ],
})

new Slider('#demo-fade-auto', {
  loop: true,
  speed: 1200,
  plugins: [
    fadeEffect({ crossFade: true }),
    autoplay({ delay: 3500, pauseOnHover: true }),
  ],
})
</script>
