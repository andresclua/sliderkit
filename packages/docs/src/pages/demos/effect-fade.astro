---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Effect — Fade">
  <DemoViewer
    title="CSS Effect — Fade"
    description="Cross-fade transition between slides. Slides stack absolutely and opacity animates."
    code={`import { fadeEffect } from '@acslider/effects'

new Slider('#el', {
  slidesPerPage: 1,
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [fadeEffect({ crossFade: true }), arrows()],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-fade">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-fade-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@acslider/core'
import { arrows, pagination } from '@acslider/plugins'
import { fadeEffect } from '@acslider/effects'

new Slider('#demo-fade', {
  slidesPerPage: 1,
  loop: false,
  rewind: true,
  speed: 600,
  plugins: [
    fadeEffect({ crossFade: true }),
    arrows(),
    pagination({ el: '#demo-fade-pag', type: 'dots', clickable: true }),
  ],
})
</script>
