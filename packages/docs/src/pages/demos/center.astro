---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Center Mode">
  <DemoViewer
    title="Center Mode"
    description="center:true keeps the active slide centred in the viewport. Adjacent slides peek in from both sides."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
  <div class="demo-slide s-pink">6</div>
</div>`}
    css={`.demo-slide { height: 260px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; border-radius:8px; opacity:.45; transition:opacity .3s; }
.sliderkit__item--active .demo-slide { opacity:1; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  center: true,
  edgePadding: 80,
  gutter: 16,
  loop: true,
  speed: 300,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})`}
  >
    <div id="demo-center">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
      <div class="demo-slide s-pink">6</div>
    </div>
  </DemoViewer>
</DemoLayout>

<style>
.demo-slide {
  border-radius: 8px;
  opacity: .45;
  transition: opacity .3s;
}
:global(.sliderkit__item--active) .demo-slide {
  opacity: 1;
}
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows, pagination } from '@andresclua/sliderkit-plugins'

new Slider('#demo-center', {
  items: 1,
  center: true,
  edgePadding: 80,
  gutter: 16,
  loop: true,
  speed: 300,
  plugins: [
    arrows(),
    pagination({ type: 'dots', clickable: true }),
  ],
})
</script>
