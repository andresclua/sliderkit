---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Auto Height">
  <DemoViewer
    title="Auto Height"
    description="autoHeight:true animates the container height to match each slide's natural height on every navigation."
    html={`<div id="my-slider">
  <div class="demo-slide s-purple ah-short">Short</div>
  <div class="demo-slide s-blue ah-medium">Medium height</div>
  <div class="demo-slide s-green ah-tall">Tall slide content</div>
  <div class="demo-slide s-amber ah-short">Short again</div>
  <div class="demo-slide s-red ah-medium">Medium again</div>
</div>`}
    css={`.ah-short  { height: 120px; }
.ah-medium { height: 200px; }
.ah-tall   { height: 300px; }
.demo-slide { display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:700; color:#fff; }`}
    js={`import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#my-slider', {
  items: 1,
  loop: false,
  rewind: true,
  autoHeight: true,
  speed: 300,
  plugins: [arrows()],
})`}
  >
    <div id="demo-autoheight">
      <div class="demo-slide s-purple ah-1">Short</div>
      <div class="demo-slide s-blue   ah-2">Medium height</div>
      <div class="demo-slide s-green  ah-3">Tall slide content</div>
      <div class="demo-slide s-amber  ah-1">Short again</div>
      <div class="demo-slide s-red    ah-2">Medium again</div>
    </div>
  </DemoViewer>
</DemoLayout>

<style>
.ah-1 { height: 120px !important; }
.ah-2 { height: 200px !important; }
.ah-3 { height: 300px !important; }
</style>

<script>
import { Slider } from '@andresclua/sliderkit'
import { arrows } from '@andresclua/sliderkit-plugins'

new Slider('#demo-autoheight', {
  items: 1,
  loop: false,
  rewind: true,
  autoHeight: true,
  speed: 300,
  plugins: [arrows()],
})
</script>
