---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="Slide Counter">
  <DemoViewer
    title="Slide Counter"
    description='Overlay badge in the top-right corner showing "2 / 5".'
    code={`import { slideCounter } from '@acslider/plugins'

new Slider('#el', {
  plugins: [arrows(), slideCounter()],
})`}
  >
    <div class="c--slider-a" id="demo-counter">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide demo-slide s-purple" data-slide>1</div>
        <div class="c--slider-a__slide demo-slide s-blue"   data-slide>2</div>
        <div class="c--slider-a__slide demo-slide s-green"  data-slide>3</div>
        <div class="c--slider-a__slide demo-slide s-amber"  data-slide>4</div>
        <div class="c--slider-a__slide demo-slide s-red"    data-slide>5</div>
      </div>
    </div>
    <div id="demo-counter-pag" class="c--slider-a__pagination"></div>
  </DemoViewer>
</DemoLayout>

<script>
import { Slider } from '@acslider/core'
import { arrows, slideCounter, pagination } from '@acslider/plugins'

new Slider('#demo-counter', {
  loop: true,
  plugins: [
    arrows(),
    slideCounter(),
    pagination({ el: '#demo-counter-pag', type: 'dots', clickable: true }),
  ],
})
</script>
