{
  "name": "acslider-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "ACSlider monorepo — a modern, accessible slider library",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='@acslider/*' build",
    "build:core": "pnpm --filter @acslider/core build",
    "build:plugins": "pnpm --filter @acslider/plugins build",
    "build:effects": "pnpm --filter @acslider/effects build",
    "build:webgl": "pnpm --filter @acslider/webgl build",
    "dev": "pnpm --filter acslider-playground dev",
    "docs": "pnpm --filter acslider-docs dev",
    "docs:build": "pnpm --filter acslider-docs build",
    "lint": "eslint packages/*/src --ext .ts",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size-check": "pnpm -r size-check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "vite": "^5.2.12"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
